}

> {% 
  client.test("wechat prepay success", function() {
    client.assert(response.status === 200, "http status should be 200");
    client.assert(response.body.code === 0, "biz code should be 0");
    client.assert(!!response.body.data.outTradeNo, "outTradeNo should exist");
  });
  client.global.set("familyOutTradeNo", response.body.data.outTradeNo);
%}

### 12) 微信充值订单查询
GET {{baseUrl}}/api/family/payment/recharge-orders/{{familyOutTradeNo}}
Authorization: Bearer {{familyToken}}

> {% 
  client.test("query recharge order success", function() {
    client.assert(response.status === 200, "http status should be 200");
    client.assert(response.body.code === 0, "biz code should be 0");
    client.assert(response.body.data.outTradeNo === client.global.get("familyOutTradeNo"), "outTradeNo should match");
  });
%}

### 13) 微信回调模拟（仅测试环境，且建议保持 skip-notify-signature-verify=true）
POST {{baseUrl}}/api/family/payment/wechat/notify
Content-Type: application/json
Wechatpay-Serial: MOCK_SERIAL
Wechatpay-Signature: MOCK_SIGNATURE
Wechatpay-Timestamp: 1719892800
Wechatpay-Nonce: nonce123

{
  "id": "EVT_202603080001",
  "event_type": "TRANSACTION.SUCCESS",
  "resource_type": "encrypt-resource",
  "summary": "支付成功",
  "resource": {
    "algorithm": "AEAD_AES_256_GCM",
    "ciphertext": "",
    "nonce": "",
    "associated_data": ""
  },
  "out_trade_no": "{{familyOutTradeNo}}",
  "trade_state": "SUCCESS",
  "transaction_id": "4200000000000000001",
  "amount": {
    "total": 9900
  },
  "success_time": "2026-03-08T16:40:00+08:00"
}

> {% 
  client.test("wechat notify handled", function() {
    client.assert(response.status === 200, "http status should be 200");
    client.assert(response.body.code === "SUCCESS" || response.body.code === "FAIL", "notify result should be returned");
  });
%}

