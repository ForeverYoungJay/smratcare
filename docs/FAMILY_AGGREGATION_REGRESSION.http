### 5) 安全设置 - 更新
PUT {{baseUrl}}/api/family/security-settings
Authorization: Bearer {{familyToken}}
Content-Type: application/json

{
  "verifyHealthData": true,
  "verifyMedicalRecords": true,
  "verifyReports": true,
  "verifyWithSmsCode": true,
  "maskSensitiveData": true,
  "visibleScope": "仅子女可查看完整健康数据"
}

> {% 
  client.test("update security settings success", function() {
    client.assert(response.status === 200, "http status should be 200");
    client.assert(response.body.code === 0, "biz code should be 0");
    client.assert(response.body.data.visibleScope === "仅子女可查看完整健康数据", "visibleScope should match");
  });
%}

### 6) 安全验证码 - 发送（登录后敏感信息校验场景）
POST {{baseUrl}}/api/family/security/sms-code/send
Authorization: Bearer {{familyToken}}
Content-Type: application/json

{
  "scene": "SECURITY"
}

> {% 
  client.test("send security sms code success", function() {
    client.assert(response.status === 200, "http status should be 200");
    client.assert(response.body.code === 0, "biz code should be 0");
    client.assert(response.body.data.expireSeconds !== undefined, "expireSeconds should exist");
  });
  if (response.body && response.body.data && response.body.data.debugCode) {
    client.global.set("familySecurityVerifyCode", response.body.data.debugCode);
  }
%}

### 7) 安全验证码 - 校验
POST {{baseUrl}}/api/family/security/sms-code/verify
Authorization: Bearer {{familyToken}}
Content-Type: application/json

{
  "scene": "SECURITY",
  "verifyCode": "{{familySecurityVerifyCode}}"
}

> {% 
  client.test("verify security sms code success", function() {
    client.assert(response.status === 200, "http status should be 200");
    client.assert(response.body.code === 0, "biz code should be 0");
    client.assert(response.body.data.passed === true, "sms code should pass");
  });
%}

