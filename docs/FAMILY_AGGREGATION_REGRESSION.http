### Family 聚合接口 HTTP 回归脚本
### 使用方式（JetBrains / VSCode REST Client）：
### 1) 先执行短信验证码发送，再执行 Family Login 获取 token
### 2) 再按顺序执行充值、安全设置、沟通消息（含语音）、FAQ、微信预下单与订单查询
### 3) 如需验证微信回调，先确认 app.family.wechat-pay.skip-notify-signature-verify=true（仅测试环境）

@baseUrl = http://localhost:8080
@orgId = 1
@familyPhone = 13800138000
@familyVerifyCode = 123456
@familySecurityVerifyCode = 123456
@familyElderId = 1
@familyAlbumId = 1
@familyPayerOpenId = oMockOpenId123
@familyTodoKey = TODO-PLACEHOLDER

### 1) 发送登录验证码（本地 mock 默认会返回 debugCode）
POST {{baseUrl}}/api/auth/family/sms-code/send
Content-Type: application/json

{
  "orgId": {{orgId}},
  "phone": "{{familyPhone}}",
  "scene": "LOGIN"
}

> {% 
  client.test("send family login sms code success", function() {
    client.assert(response.status === 200, "http status should be 200");
    client.assert(response.body.code === 0, "biz code should be 0");
    client.assert(response.body.data.expireSeconds !== undefined, "expireSeconds should exist");
  });
  if (response.body && response.body.data && response.body.data.debugCode) {
    client.global.set("familyVerifyCode", response.body.data.debugCode);
  }
%}

### 2) 家属登录（提取 token）
POST {{baseUrl}}/api/auth/family/login
Content-Type: application/json

{
  "orgId": {{orgId}},
  "phone": "{{familyPhone}}",
  "verifyCode": "{{familyVerifyCode}}"
}

> {% 
  client.test("family login success", function() {
    client.assert(response.status === 200, "http status should be 200");
    client.assert(response.body.code === 0, "biz code should be 0");
    client.assert(!!response.body.data.token, "token should exist");
  });
  client.global.set("familyToken", response.body.data.token);
%}

### 2.1) 绑定微信通知 openId（真实投递前置）
POST {{baseUrl}}/api/family/wechat/notify/bind-openid
Authorization: Bearer {{familyToken}}
Content-Type: application/json

{
  "openId": "{{familyPayerOpenId}}"
}

> {% 
  client.test("bind wechat notify openid success", function() {
    client.assert(response.status === 200, "http status should be 200");
    client.assert(response.body.code === 0, "biz code should be 0");
    client.assert(response.body.data.bound === true, "bound should be true");
  });
%}

### 2.2) 能力状态总览（短信/通知/支付/安全/旧接口）
GET {{baseUrl}}/api/family/capabilities/status
Authorization: Bearer {{familyToken}}

> {% 
  client.test("get capability status success", function() {
    client.assert(response.status === 200, "http status should be 200");
    client.assert(response.body.code === 0, "biz code should be 0");
    client.assert(response.body.data.smsEnabled !== undefined, "smsEnabled should exist");
    client.assert(Array.isArray(response.body.data.items), "items should be array");
  });
%}

### 3) 充值（业务记账路径）
POST {{baseUrl}}/api/family/payment/recharge
Authorization: Bearer {{familyToken}}
Content-Type: application/json

{
  "elderId": {{familyElderId}},
  "amount": 88,
  "method": "HTTP_REGRESSION",
  "remark": "http回归充值"
}

> {% 
  client.test("manual recharge success", function() {
    client.assert(response.status === 200, "http status should be 200");
    client.assert(response.body.code === 0, "biz code should be 0");
    client.assert(!!response.body.data.outTradeNo, "outTradeNo should exist");
  });
%}

