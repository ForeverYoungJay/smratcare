### 17) 待办中心（新增）
GET {{baseUrl}}/api/family/todo-center?elderId={{familyElderId}}
Authorization: Bearer {{familyToken}}

> {% 
  client.test("get todo center success", function() {
    client.assert(response.status === 200, "http status should be 200");
    client.assert(response.body.code === 0, "biz code should be 0");
    client.assert(response.body.data.summary !== undefined, "summary should exist");
    client.assert(Array.isArray(response.body.data.items), "items should be array");
  });
  if (response.body && response.body.data && Array.isArray(response.body.data.items)) {
    const actionable = response.body.data.items.find(item => item && item.todoKey && item.actionable === true);
    if (actionable) {
      client.global.set("familyTodoKey", actionable.todoKey);
    }
  }
%}

