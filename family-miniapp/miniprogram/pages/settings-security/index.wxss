.card {
  padding: 24rpx;
}

.item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e5eaef;
}

.item-title {
  font-size: 26rpx;
  color: #1f2937;
}

.item-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.5;
}

.scope-panel {
  margin-top: 18rpx;
  padding: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #d9e3ea;
  border-radius: 14rpx;
}

.scope-picker {
  margin-top: 10rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #ffffff;
  border: 1rpx solid #d6dfe8;
  font-size: 25rpx;
  color: #1f2937;
}

.password-panel {
  margin-top: 14rpx;
  padding: 14rpx;
  border: 1rpx solid #d9e3ea;
  border-radius: 12rpx;
  background: #f8fafc;
}

.password-btn {
  margin-top: 10rpx;
  width: 180rpx;
  height: 58rpx;
  line-height: 58rpx;
  font-size: 22rpx;
}
