/* ===== 员工待办 · 优先级醒目 ===== */

/* 顶部统计：数字大而醒目 */
.summary-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.summary-card {
  padding: 22rpx 12rpx;
  text-align: center;
}

.summary-card text,
.summary-card strong {
  display: block;
}

.summary-card text {
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 700;
}

.summary-card strong {
  margin-top: 10rpx;
  color: var(--brand);
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
}

/* 今日：warning 浅底 */
.summary-card.warning {
  background: #FBF0E2;
  border-color: rgba(222, 155, 61, 0.45);
}

.summary-card.warning text {
  color: #B27221;
}

.summary-card.warning strong {
  color: #B27221;
}

/* 逾期：红底白字，最醒目 */
.summary-card.danger {
  background: var(--danger);
  border-color: var(--danger);
  box-shadow: 0 6rpx 16rpx rgba(201, 80, 75, 0.28);
}

.summary-card.danger text {
  color: rgba(255, 255, 255, 0.88);
}

.summary-card.danger strong {
  color: #ffffff;
}

/* 搜索 */
.search-row {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border-radius: var(--radius-ctl);
  border: 1rpx solid var(--border);
  background: var(--card);
  color: var(--ink);
  font-size: 26rpx;
}

.search-btn {
  flex: none;
  width: 148rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 27rpx;
}

/* 筛选胶囊 */
.filter-row {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  margin: 20rpx 0 0;
  padding-bottom: 4rpx;
}

.filter-row.compact {
  margin-top: 12rpx;
}

.filter {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  min-height: 60rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: var(--card);
  border: 1rpx solid var(--border);
  color: var(--muted);
  font-size: 25rpx;
  font-weight: 700;
}

.filter.source {
  background: var(--accent-soft);
  border-color: rgba(229, 138, 58, 0.35);
  color: #A9631F;
}

.filter.active {
  background: linear-gradient(135deg, #21705F, #2E8A72);
  border-color: transparent;
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(33, 112, 95, 0.24);
}

.retry-btn {
  margin-top: 20rpx;
}

.empty-card {
  margin-top: 18rpx;
  padding: 34rpx;
}

/* 待办卡片 */
.todo-card {
  margin-top: 18rpx;
  padding: 26rpx;
}

.todo-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.todo-title {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.4;
}

.todo-meta,
.todo-foot {
  margin-top: 8rpx;
  color: var(--faint);
  font-size: 22rpx;
}

/* 状态徽章：待处理 warning 浅底深字 / 已完成 success */
.status-pill {
  flex: none;
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #FBF0E2;
  color: #B27221;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
}

.status-pill.done {
  background: #E7F4EC;
  color: var(--success);
}

.todo-content {
  margin-top: 16rpx;
  color: var(--muted);
  font-size: 26rpx;
  line-height: 1.55;
}

.todo-foot {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

/* 操作按钮：整行大按钮，易点 */
.action-row {
  margin-top: 22rpx;
}

.action-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
}
