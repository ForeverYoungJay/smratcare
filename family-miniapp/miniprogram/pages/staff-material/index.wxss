.form-card {
  margin-top: 22rpx;
  padding: 26rpx;
}

.field {
  margin-top: 22rpx;
}

.field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #60716b;
  font-size: 23rpx;
  font-weight: 850;
}

.picker-line,
.input-line,
.textarea-line {
  width: 100%;
  border-radius: 14rpx;
  border: 1rpx solid #d9e3df;
  background: #ffffff;
  color: #182420;
  font-size: 25rpx;
}

.picker-line,
.input-line {
  min-height: 74rpx;
  line-height: 74rpx;
  padding: 0 18rpx;
}

.textarea-line {
  min-height: 150rpx;
  padding: 18rpx;
  line-height: 1.55;
}

.submit-btn {
  width: 100%;
  margin-top: 24rpx;
}

.retry-btn {
  margin-top: 20rpx;
}

.empty-card {
  margin-top: 18rpx;
  padding: 34rpx;
}

.material-card {
  margin-top: 18rpx;
  padding: 26rpx;
}

.material-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.material-title {
  color: #182430;
  font-size: 30rpx;
  font-weight: 900;
}

.material-meta {
  margin-top: 8rpx;
  color: #73808c;
  font-size: 22rpx;
}

.status-pill {
  flex: none;
  height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #fff2d9;
  color: #9a5b05;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 46rpx;
}

.status-pill.success {
  background: #e5f5ef;
  color: #16704f;
}

.status-pill.danger {
  background: #fde8e5;
  color: #b42318;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag-row text {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #f1f5f4;
  color: #60706b;
  font-size: 21rpx;
  font-weight: 800;
}

.material-reason {
  margin-top: 14rpx;
  color: #465563;
  font-size: 24rpx;
  line-height: 1.55;
}
