.card {
  padding: 24rpx;
  overflow: hidden;
}

.top-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.tag.urgent {
  background: #ffefef;
  color: #C9504B;
}

.tag.warning {
  background: #fff4e8;
  color: #B27221;
}

.tag.normal {
  background: #E8F3EF;
  color: #21705F;
}

.time {
  font-size: 22rpx;
  color: #5C6F69;
  line-height: 1.5;
}

.title {
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #22332E;
  line-height: 1.45;
  word-break: break-word;
}

.meta,
.content {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #34443f;
  line-height: 1.6;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.section {
  margin-top: 20rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #22332E;
}

.timeline-row {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #52615c;
  padding: 12rpx 14rpx;
  background: #FAFAF7;
  border-radius: 14rpx;
  line-height: 1.65;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.action-row {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.action {
  margin-top: 0;
}

.action-primary,
.action-secondary {
  flex: 1;
  min-width: 240rpx;
}
