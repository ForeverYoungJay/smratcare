.card {
  padding: 24rpx;
  overflow: hidden;
}

.top-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.tag.urgent {
  background: #ffefef;
  color: #b91c1c;
}

.tag.warning {
  background: #fff4e8;
  color: #b45309;
}

.tag.normal {
  background: #eef7f8;
  color: #1f4f57;
}

.time {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.5;
}

.title {
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.45;
  word-break: break-word;
}

.meta,
.content {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #374151;
  line-height: 1.6;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.section {
  margin-top: 20rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #1f2937;
}

.timeline-row {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #4b5563;
  padding: 12rpx 14rpx;
  background: #f8fafc;
  border-radius: 14rpx;
  line-height: 1.65;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.action-row {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.action {
  margin-top: 0;
}

.action-primary,
.action-secondary {
  flex: 1;
  min-width: 240rpx;
}
