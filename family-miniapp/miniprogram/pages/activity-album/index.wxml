<view class="container">
  <view class="surface card">
    <view class="section-title">相册 / 视频</view>
    <view class="album-tabs">
      <block wx:for="{{tabs}}" wx:key="key">
        <view
          class="album-tab {{activeScope === item.key ? 'active' : ''}}"
          data-scope="{{item.key}}"
          bindtap="switchScope">
          {{item.title}}
        </view>
      </block>
    </view>
    <view class="empty" wx:if="{{loading}}">相册加载中...</view>
    <view class="error-box" wx:if="{{!loading && loadError}}">
      <view class="error-text">{{loadError}}</view>
      <button class="ghost-btn retry-btn" bindtap="retryLoad">重新加载</button>
    </view>
    <view class="empty" wx:if="{{!loading && !loadError && list.length === 0}}">
      {{activeScope === 'PERSONAL' ? '暂无个人相册' : '暂无集体活动相册'}}
    </view>
    <block wx:if="{{!loading && !loadError}}" wx:for="{{list}}" wx:key="id">
      <view class="item">
        <video
          wx:if="{{item.isVideo && item.resolvedMediaUrl}}"
          class="cover-video"
          src="{{item.resolvedMediaUrl}}"
          controls="{{true}}"
          enable-danmu="{{true}}"
          danmu-btn="{{true}}"
          object-fit="cover" />
        <image
          wx:elif="{{item.resolvedCoverUrl}}"
          class="cover-image"
          src="{{item.resolvedCoverUrl}}"
          mode="aspectFill"
          data-url="{{item.resolvedCoverUrl}}"
          bindtap="previewPhoto" />
        <view wx:else class="cover">{{item.coverText}}</view>
        <view class="name">{{item.title}}</view>
        <view class="meta">{{item.elderName}} · {{item.date}} · {{item.scopeText}}</view>
        <view class="desc">{{item.description}}</view>
        <view class="actions">
          <button class="ghost-btn small" data-id="{{item.id}}" bindtap="like">{{item.liked ? '取消赞' : '点赞'}} {{item.likes}}</button>
          <button class="ghost-btn small" data-id="{{item.id}}" bindtap="openComments">
            {{activeAlbumId === item.id ? '收起评论' : '评论 ' + item.comments}}
          </button>
        </view>

        <view class="comment-panel" wx:if="{{activeAlbumId === item.id}}">
          <view class="comment-title">评论互动</view>
          <view class="comment-loading" wx:if="{{loadingComments}}">评论加载中...</view>
          <view class="comment-empty" wx:if="{{!loadingComments && comments.length === 0}}">暂无评论，欢迎留言。</view>
          <block wx:if="{{!loadingComments && comments.length > 0}}" wx:for="{{comments}}" wx:for-item="comment" wx:key="id">
            <view class="comment-row">
              <view class="comment-head">
                <text class="commenter">{{comment.commenter}}</text>
                <text class="comment-time">{{comment.time}}</text>
              </view>
              <view class="comment-content">{{comment.content}}</view>
            </view>
          </block>
          <view class="comment-editor">
            <input
              class="comment-input"
              placeholder="写下你的互动留言"
              value="{{commentInput}}"
              maxlength="200"
              bindinput="onCommentInput" />
            <button class="primary-btn comment-btn" loading="{{commenting}}" bindtap="submitComment">发送</button>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
