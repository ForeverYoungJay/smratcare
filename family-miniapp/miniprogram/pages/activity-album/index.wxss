.card { padding: 24rpx; }
.item { margin-top: 14rpx; padding: 14rpx; border: 1rpx solid #e5edf2; border-radius: 12rpx; background: #f8fafc; }
.cover { height: 120rpx; border-radius: 10rpx; background: linear-gradient(120deg, #dbeafe, #eef7f8); display: flex; align-items: center; justify-content: center; color: #1f4f57; font-size: 22rpx; }
.cover-image { width: 100%; height: 240rpx; border-radius: 10rpx; background: #eef4f8; }
.name { margin-top: 8rpx; font-size: 27rpx; color: #111827; font-weight: 700; }
.meta { margin-top: 6rpx; font-size: 22rpx; color: #6b7280; }
.desc { margin-top: 6rpx; font-size: 23rpx; color: #374151; }
.actions { margin-top: 10rpx; display: flex; align-items: center; gap: 12rpx; }
.small { width: 170rpx; height: 56rpx; line-height: 56rpx; font-size: 22rpx; }
.comment { font-size: 22rpx; color: #6b7280; }
.comment-panel { margin-top: 12rpx; padding: 12rpx; border: 1rpx solid #d8e2e8; border-radius: 10rpx; background: #fff; }
.comment-title { font-size: 24rpx; color: #334155; font-weight: 600; }
.comment-loading, .comment-empty { margin-top: 8rpx; font-size: 22rpx; color: #64748b; }
.comment-row { margin-top: 10rpx; padding: 10rpx; border-radius: 8rpx; background: #f8fafc; }
.comment-head { display: flex; justify-content: space-between; align-items: center; }
.commenter { font-size: 23rpx; color: #1f2937; font-weight: 600; }
.comment-time { font-size: 20rpx; color: #94a3b8; }
.comment-content { margin-top: 4rpx; font-size: 23rpx; color: #334155; }
.comment-editor { margin-top: 10rpx; display: flex; gap: 10rpx; align-items: center; }
.comment-input { flex: 1; height: 64rpx; padding: 0 14rpx; border: 1rpx solid #cbd5e1; border-radius: 10rpx; background: #fff; font-size: 24rpx; }
.comment-btn { min-width: 128rpx; height: 64rpx; line-height: 64rpx; font-size: 22rpx; }
