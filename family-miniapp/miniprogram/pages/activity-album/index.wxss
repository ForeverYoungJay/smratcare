.card { padding: 24rpx; }
.album-tabs { margin-top: 16rpx; display: flex; gap: 12rpx; padding: 8rpx; border-radius: 12rpx; background: #E8F3EF; }
.album-tab { flex: 1; height: 64rpx; line-height: 64rpx; text-align: center; border-radius: 10rpx; color: #47615a; font-size: 24rpx; }
.album-tab.active { background: #21705F; color: #fff; font-weight: 700; }
.empty { margin-top: 20rpx; padding: 32rpx 0; text-align: center; color: #5C6F69; font-size: 24rpx; background: #FAFAF7; border-radius: 12rpx; }
.item { margin-top: 14rpx; padding: 14rpx; border: 1rpx solid #E4E7E0; border-radius: 12rpx; background: #FAFAF7; }
.cover { height: 120rpx; border-radius: 10rpx; background: linear-gradient(120deg, #dbeafe, #E8F3EF); display: flex; align-items: center; justify-content: center; color: #21705F; font-size: 22rpx; }
.cover-image,
.cover-video { width: 100%; height: 240rpx; border-radius: 10rpx; background: #eef4f8; }
.name { margin-top: 8rpx; font-size: 27rpx; color: #22332E; font-weight: 700; }
.meta { margin-top: 6rpx; font-size: 22rpx; color: #5C6F69; }
.desc { margin-top: 6rpx; font-size: 23rpx; color: #34443f; }
.actions { margin-top: 10rpx; display: flex; align-items: center; gap: 12rpx; }
.small { width: 170rpx; height: 56rpx; line-height: 56rpx; font-size: 22rpx; }
.comment { font-size: 22rpx; color: #5C6F69; }
.comment-panel { margin-top: 12rpx; padding: 12rpx; border: 1rpx solid #d8e2e8; border-radius: 10rpx; background: #fff; }
.comment-title { font-size: 24rpx; color: #334155; font-weight: 600; }
.comment-loading, .comment-empty { margin-top: 8rpx; font-size: 22rpx; color: #5C6F69; }
.comment-row { margin-top: 10rpx; padding: 10rpx; border-radius: 8rpx; background: #FAFAF7; }
.comment-head { display: flex; justify-content: space-between; align-items: center; }
.commenter { font-size: 23rpx; color: #22332E; font-weight: 600; }
.comment-time { font-size: 20rpx; color: #94a3b8; }
.comment-content { margin-top: 4rpx; font-size: 23rpx; color: #334155; }
.comment-editor { margin-top: 10rpx; display: flex; gap: 10rpx; align-items: center; }
.comment-input { flex: 1; height: 64rpx; padding: 0 14rpx; border: 1rpx solid #cbd5e1; border-radius: 10rpx; background: #fff; font-size: 24rpx; }
.comment-btn { min-width: 128rpx; height: 64rpx; line-height: 64rpx; font-size: 22rpx; }
.error-box { padding: 30rpx 0; text-align: center; }
.error-text { font-size: 23rpx; color: #B4553B; line-height: 1.6; }
.retry-btn { margin-top: 14rpx; display: inline-block; height: 60rpx; line-height: 60rpx; font-size: 23rpx; padding: 0 30rpx; }

.section-title-row { display: flex; align-items: center; justify-content: space-between; }
.subscribe-link { font-size: 24rpx; color: #21705F; }
