.card {
  padding: 24rpx;
}

.support-box {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #FAFAF7;
  border: 1rpx solid #dbe3ea;
}

.support-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #22332E;
}

.support-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #5C6F69;
}

.group {
  margin-top: 18rpx;
}

.group-title {
  font-size: 24rpx;
  color: #21705F;
  font-weight: 700;
}

.qa-card {
  margin-top: 10rpx;
  padding: 16rpx;
  background: #FAFAF7;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
}

.qa {
  font-size: 25rpx;
  color: #22332E;
  font-weight: 700;
}

.ans {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.7;
}

.action {
  margin-top: 16rpx;
}
