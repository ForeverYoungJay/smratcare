.card { padding: 24rpx; }
.day-block { margin-top: 14rpx; }
.day { font-size: 26rpx; color: #246b5f; font-weight: 700; }
.row { margin-top: 10rpx; display: flex; gap: 12rpx; background: #f7faf8; border-radius: 10rpx; padding: 12rpx; }
.time { width: 84rpx; font-size: 22rpx; color: #71807a; }
.main { flex: 1; }
.project { display: block; font-size: 25rpx; color: #16231f; font-weight: 600; }
.staff { display: block; margin-top: 4rpx; font-size: 22rpx; color: #71807a; }
.note { display: block; margin-top: 4rpx; font-size: 22rpx; color: #34443f; }
.photo-row { margin-top: 8rpx; display: flex; gap: 8rpx; flex-wrap: wrap; }
.photo { width: 140rpx; height: 100rpx; border-radius: 8rpx; background: #dbeafe; }
