<view class="container">
  <view class="surface bind-card">
    <view class="section-title">绑定入住老人</view>
    <view class="section-subtitle">支持扫码院内二维码或手动填写老人身份证号</view>
    <button class="ghost-btn" bindtap="scanCode">扫码绑定（推荐）</button>

    <view class="field">
      <text class="label">老人身份证号</text>
      <input class="input" maxlength="18" value="{{form.elderIdCardNo}}" bindinput="onIdCardInput" placeholder="请输入15位或18位身份证号" />
      <view class="hint">优先使用身份证匹配，兼容旧版二维码中的老人ID</view>
    </view>

    <view class="field">
      <text class="label">关系</text>
      <picker mode="selector" range="{{relations}}" value="{{relationIndex}}" bindchange="onRelationChange">
        <view class="picker">{{relations[relationIndex]}}</view>
      </picker>
    </view>

    <view class="field switch-field">
      <text class="label">设为主要联系人</text>
      <switch checked="{{form.isPrimary === 1}}" bindchange="onPrimaryChange" color="#2c7a84" />
    </view>

    <view class="field">
      <text class="label">备注</text>
      <textarea class="textarea" value="{{form.remark}}" bindinput="onRemarkInput" maxlength="120" placeholder="例如：仅子女可查看完整健康档案" />
    </view>

    <button class="primary-btn" bindtap="onBind" loading="{{loading}}">完成绑定</button>
  </view>
</view>
