.container {
  min-height: 100vh;
}

.bind-card {
  padding: 34rpx 28rpx 30rpx;
  background:
    radial-gradient(circle at top right, rgba(240, 199, 135, 0.2) 0%, rgba(240, 199, 135, 0) 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 251, 252, 0.94));
}

.ghost-btn {
  margin-top: 20rpx;
}

.field {
  margin-top: 24rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.input,
.picker,
.textarea {
  background: rgba(248, 250, 252, 0.95);
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  border-radius: 18rpx;
  padding: 22rpx 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.picker {
  color: #1f2937;
}

.textarea {
  min-height: 168rpx;
}

.hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.7;
}

.switch-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

@media screen and (max-width: 360px) {
  .bind-card {
    padding: 30rpx 22rpx 24rpx;
  }

  .switch-field {
    flex-direction: column;
    align-items: flex-start;
  }
}
