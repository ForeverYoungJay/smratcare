.bind-card {
  padding: 30rpx;
}

.ghost-btn {
  margin-top: 16rpx;
}

.field {
  margin-top: 20rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #5C6F69;
  margin-bottom: 10rpx;
}

.input,
.picker,
.textarea {
  background: #FAFAF7;
  border: 1rpx solid #dbe3ea;
  border-radius: 14rpx;
  padding: 20rpx;
  font-size: 30rpx;
}

.picker {
  color: #22332E;
}

.textarea {
  min-height: 140rpx;
}

.hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #5C6F69;
}

.switch-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
