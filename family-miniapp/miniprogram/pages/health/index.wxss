.card {
  padding: 28rpx;
}

.verify-tip {
  margin-top: 20rpx;
  border-radius: 16rpx;
  background: #fff7e8;
  padding: 18rpx;
}

.tip-title {
  font-size: 26rpx;
  font-weight: 900;
  color: #8a5508;
}

.tip-text {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #8a5508;
  line-height: 1.55;
}

.verify-btn {
  margin-top: 14rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
}

.range-row {
  margin-top: 18rpx;
  display: flex;
  gap: 10rpx;
}

.range {
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  background: #edf2ef;
  color: #71807a;
}

.range.active {
  background: #246b5f;
  color: #ffffff;
  font-weight: 900;
}

.summary-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.summary-item {
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f7faf8;
}

.k {
  display: block;
  font-size: 22rpx;
  color: #71807a;
}

.v {
  display: block;
  margin-top: 4rpx;
  font-size: 32rpx;
  color: #16231f;
  font-weight: 900;
}

.trend-box {
  margin-top: 22rpx;
}

.trend-row {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  gap: 12rpx;
}

.date {
  width: 90rpx;
  font-size: 21rpx;
  color: #71807a;
}

.bar-wrap {
  flex: 1;
  height: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #e3ebe7;
}

.bar {
  height: 100%;
  background: #246b5f;
}

.value {
  width: 120rpx;
  text-align: right;
  font-size: 21rpx;
  color: #34443f;
}

.tips-title {
  margin-top: 22rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: #182420;
}

.tip {
  margin-top: 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: #f7faf8;
  color: #52615c;
  font-size: 23rpx;
  line-height: 1.55;
}

.action-row {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.action {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  font-size: 23rpx;
}
