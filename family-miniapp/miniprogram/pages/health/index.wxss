/* ===== 健康数据 · 数值大而醒目 ===== */

.card {
  padding: 28rpx;
}

/* ---- 二次验证提示 ---- */
.verify-tip {
  margin-top: 20rpx;
  border-radius: 16rpx;
  background: var(--accent-soft);
  border: 1rpx solid rgba(229, 138, 58, 0.25);
  padding: 22rpx;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #A96324;
}

.tip-text {
  margin-top: 8rpx;
  font-size: 25rpx;
  color: #A96324;
  line-height: 1.6;
}

.verify-btn {
  margin-top: 16rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
}

/* ---- 时间范围切换 ---- */
.range-row {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
}

.range {
  padding: 12rpx 26rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  background: #EFF2EE;
  color: var(--muted);
}

.range.active {
  background: linear-gradient(135deg, #21705F, #2E8A72);
  color: #ffffff;
  font-weight: 800;
  box-shadow: 0 4rpx 12rpx rgba(33, 112, 95, 0.25);
}

/* ---- 最新数值四宫格（数值醒目） ---- */
.summary-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.summary-item {
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  background: var(--brand-soft);
  border: 1rpx solid rgba(33, 112, 95, 0.1);
}

.k {
  display: block;
  font-size: 24rpx;
  color: var(--muted);
  font-weight: 600;
}

.v {
  display: block;
  margin-top: 6rpx;
  font-size: 44rpx;
  line-height: 1.2;
  color: var(--brand-deep);
  font-weight: 900;
}

/* ---- 趋势条 ---- */
.trend-box {
  margin-top: 24rpx;
}

.trend-row {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
  gap: 12rpx;
}

.date {
  width: 96rpx;
  font-size: 22rpx;
  color: var(--faint);
}

.bar-wrap {
  flex: 1;
  height: 16rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #E4EBE6;
}

.bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #21705F, #2E8A72);
}

.value {
  width: 128rpx;
  text-align: right;
  font-size: 24rpx;
  color: var(--ink);
  font-weight: 700;
}

/* ---- 健康建议 ---- */
.tips-title {
  margin-top: 26rpx;
  font-size: 29rpx;
  font-weight: 800;
  color: var(--ink);
}

.tip {
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  background: var(--brand-soft);
  color: var(--brand-deep);
  font-size: 26rpx;
  line-height: 1.6;
}

/* ---- 快捷操作 ---- */
.action-row {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.action {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  font-size: 25rpx;
}
