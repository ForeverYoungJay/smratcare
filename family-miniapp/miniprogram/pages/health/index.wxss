.card { padding: 24rpx; }
.verify-tip {
  margin-top: 18rpx;
  border-radius: 14rpx;
  border: 1rpx solid #d6e1e7;
  background: #f8fafc;
  padding: 16rpx;
}
.tip-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1f2937;
}
.tip-text {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #556273;
  line-height: 1.6;
}
.verify-btn {
  margin-top: 12rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
}
.range-row { margin-top: 14rpx; display: flex; gap: 10rpx; }
.range { padding: 8rpx 18rpx; border-radius: 999rpx; font-size: 23rpx; background: #eef3f7; color: #6b7280; }
.range.active { background: #194f5e; color: #fff; }
.summary-grid { margin-top: 14rpx; display: grid; grid-template-columns: 1fr 1fr; gap: 10rpx; }
.summary-item { background: #f8fafc; border-radius: 12rpx; padding: 12rpx; }
.k { display: block; font-size: 22rpx; color: #6b7280; }
.v { display: block; margin-top: 4rpx; font-size: 30rpx; color: #111827; font-weight: 700; }
.trend-box { margin-top: 18rpx; }
.trend-row { display: flex; align-items: center; margin-top: 10rpx; }
.date { width: 90rpx; font-size: 21rpx; color: #6b7280; }
.bar-wrap { flex: 1; height: 12rpx; background: #e6eef3; border-radius: 999rpx; overflow: hidden; }
.bar { height: 100%; background: linear-gradient(120deg, #2c7a84, #194f5e); }
.value { width: 120rpx; text-align: right; font-size: 21rpx; color: #374151; }
.tips-title { margin-top: 18rpx; font-size: 25rpx; font-weight: 700; color: #1f2937; }
.tip { margin-top: 8rpx; font-size: 23rpx; color: #4b5563; background: #f8fafc; border-radius: 10rpx; padding: 10rpx; }
.action-row { margin-top: 18rpx; display: flex; gap: 10rpx; }
.action { flex: 1; height: 64rpx; line-height: 64rpx; font-size: 23rpx; padding: 0; }
