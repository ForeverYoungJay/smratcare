.card {
  padding: 24rpx;
}

.line {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #374151;
  line-height: 1.6;
  display: flex;
  justify-content: space-between;
}

.label {
  min-width: 132rpx;
  color: #64748b;
}

.multiline {
  display: block;
}

.multiline .label {
  display: block;
  margin-bottom: 4rpx;
}

.action {
  margin-top: 16rpx;
}

.empty-card {
  text-align: center;
}
