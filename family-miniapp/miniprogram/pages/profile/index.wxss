.card {
  padding: 30rpx 28rpx;
}

.user-name {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #22332E;
}

.user-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5C6F69;
  line-height: 1.45;
}

.warning-tip {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #fff8ea;
  color: #8a5508;
  font-size: 22rpx;
  line-height: 1.5;
}

.menu-list {
  margin-top: 28rpx;
  overflow: hidden;
  border-radius: 16rpx;
  border: 1rpx solid #E4E7E0;
}

.menu-item {
  min-height: 86rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 18rpx;
  border-bottom: 1rpx solid #E4E7E0;
  background: #ffffff;
  font-size: 27rpx;
  color: #22332E;
  font-weight: 800;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.menu-badge {
  min-width: 32rpx;
  padding: 3rpx 8rpx;
  border-radius: 999rpx;
  background: #C9504B;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1.4;
  text-align: center;
}

.arrow {
  color: #9aa6a1;
}

.action {
  margin-top: 24rpx;
  width: 100%;
}
