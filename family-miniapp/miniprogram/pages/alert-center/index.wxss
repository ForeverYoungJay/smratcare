.hero {
  padding: 24rpx;
  background: #ffffff;
  overflow: hidden;
}

.hero-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  flex-wrap: wrap;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.mini-btn {
  height: 56rpx;
  line-height: 56rpx;
  font-size: 22rpx;
  border-radius: 999rpx;
  padding: 0 16rpx;
  min-width: 152rpx;
  margin: 0;
}

.count-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.count-card {
  background: #f7faf8;
  border: 1rpx solid #edf2ef;
  border-radius: 18rpx;
  padding: 16rpx 18rpx;
  min-width: 0;
}

.count-card .num {
  display: block;
  font-size: 34rpx;
  color: #182420;
  font-weight: 700;
}

.count-card .label {
  display: block;
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #71807a;
}

.count-card.urgent {
  background: #fff1f1;
  border-color: #f8cccc;
}

.count-card.warning {
  background: #fff7e8;
  border-color: #f2d2a1;
}

.count-card.normal {
  background: #edf6f2;
  border-color: #cde1e4;
}

.panel {
  margin-top: 18rpx;
  padding: 22rpx;
  overflow: hidden;
}

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.panel-title {
  font-size: 28rpx;
  color: #182420;
  font-weight: 700;
}

.link {
  font-size: 22rpx;
  color: #246b5f;
}

.type-row {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  flex-wrap: wrap;
  font-size: 23rpx;
  color: #34443f;
  background: #f7faf8;
  border-radius: 14rpx;
  padding: 14rpx 16rpx;
}

.type-name {
  font-weight: 700;
  max-width: 100%;
  word-break: break-word;
}

.type-count {
  color: #71807a;
  line-height: 1.5;
  word-break: break-word;
}

.urgent-item {
  margin-top: 12rpx;
  border-radius: 18rpx;
  border: 1rpx solid #f3d1d1;
  background: linear-gradient(145deg, #fffafa, #ffffff);
  padding: 16rpx;
  overflow: hidden;
}

.urgent-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.tag.lv-urgent {
  background: #ffefef;
  color: #b42318;
}

.tag.lv-warning {
  background: #fff4e8;
  color: #9a5b05;
}

.tag.lv-normal {
  background: #edf6f2;
  color: #246b5f;
}

.urgent-time {
  font-size: 22rpx;
  color: #71807a;
  line-height: 1.5;
}

.urgent-title {
  margin-top: 8rpx;
  font-size: 27rpx;
  color: #16231f;
  font-weight: 700;
  line-height: 1.45;
  word-break: break-word;
}

.urgent-content {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #475569;
  line-height: 1.55;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.urgent-bottom {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.elder {
  font-size: 22rpx;
  color: #71807a;
  min-width: 0;
  word-break: break-word;
}

.call-btn {
  min-width: 112rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 21rpx;
  margin: 0;
}
