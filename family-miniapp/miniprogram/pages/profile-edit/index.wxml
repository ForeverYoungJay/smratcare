<view class="container">
  <view class="surface card">
    <view class="field">
      <text class="label">姓名</text>
      <input class="input" value="{{profile.realName}}" data-field="realName" bindinput="onInput" />
    </view>
    <view class="field">
      <text class="label">手机号</text>
      <input class="input" value="{{profile.phone}}" data-field="phone" bindinput="onInput" />
    </view>
    <view class="field">
      <text class="label">联系地址</text>
      <input class="input" value="{{profile.address}}" data-field="address" bindinput="onInput" />
    </view>
    <view class="field">
      <text class="label">首选沟通方式</text>
      <input class="input" value="{{profile.preferredContact}}" data-field="preferredContact" bindinput="onInput" />
    </view>
    <button class="primary-btn" bindtap="save">保存信息</button>
  </view>
</view>
