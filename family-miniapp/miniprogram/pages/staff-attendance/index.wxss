.month-picker {
  margin-top: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: #edf5f2;
  color: #1f5f4c;
  font-size: 25rpx;
  font-weight: 850;
}

.retry-btn {
  margin-top: 20rpx;
}

.today-card {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 26rpx;
  background: linear-gradient(135deg, rgba(36, 107, 95, 0.13), rgba(255, 255, 255, 0) 58%), #ffffff;
}

.today-title {
  color: #182430;
  font-size: 32rpx;
  font-weight: 900;
}

.today-meta {
  margin-top: 8rpx;
  color: #73808c;
  font-size: 23rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.summary-card {
  padding: 20rpx 12rpx;
  text-align: center;
}

.summary-card text,
.summary-card strong {
  display: block;
}

.summary-card text {
  color: #73808c;
  font-size: 22rpx;
  font-weight: 800;
}

.summary-card strong {
  margin-top: 8rpx;
  color: #246b5f;
  font-size: 38rpx;
  font-weight: 900;
}

.summary-card.warning strong {
  color: #9a6400;
}

.summary-card.danger strong {
  color: #bd2e1f;
}

.day-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #edf1f5;
}

.day-row:first-of-type {
  border-top: 0;
}

.day-date {
  width: 142rpx;
}

.day-date text {
  display: block;
  color: #465563;
  font-size: 22rpx;
  font-weight: 850;
}

.day-main {
  flex: 1;
  min-width: 0;
}

.day-time {
  color: #182430;
  font-size: 25rpx;
  font-weight: 850;
}

.day-meta,
.day-alert {
  margin-top: 8rpx;
  color: #73808c;
  font-size: 22rpx;
}

.day-alert {
  color: #bd2e1f;
}

.day-status {
  color: #1f5f8b;
  font-size: 22rpx;
  font-weight: 900;
}
