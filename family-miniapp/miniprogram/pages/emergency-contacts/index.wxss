.card { padding: 24rpx; }
.item { margin-top: 12rpx; display: flex; justify-content: space-between; align-items: center; background: #f7faf8; border-radius: 12rpx; border: 1rpx solid #edf2ef; padding: 14rpx; }
.name { font-size: 27rpx; color: #16231f; font-weight: 700; }
.duty { margin-top: 6rpx; font-size: 22rpx; color: #71807a; }
.small { width: 120rpx; height: 58rpx; line-height: 58rpx; font-size: 22rpx; }
