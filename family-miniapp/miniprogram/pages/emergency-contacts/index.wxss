.card { padding: 24rpx; }
.item { margin-top: 12rpx; display: flex; justify-content: space-between; align-items: center; background: #FAFAF7; border-radius: 12rpx; border: 1rpx solid #E4E7E0; padding: 14rpx; }
.name { font-size: 27rpx; color: #22332E; font-weight: 700; }
.duty { margin-top: 6rpx; font-size: 22rpx; color: #5C6F69; }
.small { width: 120rpx; height: 58rpx; line-height: 58rpx; font-size: 22rpx; }
