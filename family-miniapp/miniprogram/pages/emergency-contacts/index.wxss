.card { padding: 24rpx; }
.item { margin-top: 12rpx; display: flex; justify-content: space-between; align-items: center; background: #f8fafc; border-radius: 12rpx; border: 1rpx solid #e5edf2; padding: 14rpx; }
.name { font-size: 27rpx; color: #111827; font-weight: 700; }
.duty { margin-top: 6rpx; font-size: 22rpx; color: #6b7280; }
.small { width: 120rpx; height: 58rpx; line-height: 58rpx; font-size: 22rpx; }
