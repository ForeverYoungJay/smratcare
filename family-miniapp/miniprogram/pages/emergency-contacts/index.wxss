.page-head { padding: 6rpx 8rpx 20rpx; }
.loading-tip { padding: 40rpx; text-align: center; color: var(--faint); font-size: 26rpx; }

.contact-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 16rpx;
}

.contact-avatar {
  flex: none;
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: var(--brand-gradient);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.contact-main { flex: 1; min-width: 0; }
.contact-name { font-size: 29rpx; font-weight: 800; color: var(--ink); }
.contact-role { font-size: 24rpx; font-weight: 600; color: var(--muted); }
.contact-duty { margin-top: 6rpx; font-size: 23rpx; color: var(--muted); }
.contact-phone { margin-top: 6rpx; font-size: 25rpx; color: var(--brand); letter-spacing: 1rpx; }

.call-btn {
  flex: none;
  width: 132rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: var(--brand);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 700;
}
.call-btn::after { border: 0; }
