/* ===== 首页 · 温暖易读 ===== */

.home-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin: 6rpx 0 24rpx;
}

.mini-btn {
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: var(--card);
  border: 1rpx solid rgba(33, 112, 95, 0.35);
  color: var(--brand);
  font-size: 25rpx;
  font-weight: 800;
  box-shadow: var(--shadow);
}

/* ---- 老人切换 ---- */
.switch-panel {
  margin-bottom: 18rpx;
  padding: 18rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: none;
}

.switch-label {
  font-size: 24rpx;
  color: var(--muted);
  font-weight: 700;
}

.switch-pick {
  min-width: 360rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: var(--brand-soft);
  color: var(--brand-deep);
  font-size: 26rpx;
  font-weight: 800;
  text-align: center;
}

/* ---- 老人卡片（品牌渐变，层次醒目） ---- */
.elder-swiper {
  height: 540rpx;
}

.elder-card {
  min-height: 510rpx;
  height: auto;
  padding: 28rpx;
  overflow: hidden;
  border: none;
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, #21705F, #2E8A72);
  box-shadow: 0 10rpx 28rpx rgba(33, 112, 95, 0.28);
}

.card-top {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex: 0 0 92rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 900;
}

.basic {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
}

.elder-name {
  flex: 1;
  min-width: 0;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.elder-card .meta {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
  line-height: 1.35;
}

.special-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.special-tag {
  max-width: 370rpx;
  padding: 7rpx 18rpx;
  border-radius: 999rpx;
  background: var(--accent-soft);
  color: #A96324;
  font-size: 22rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.update {
  color: rgba(255, 255, 255, 0.72);
  font-size: 21rpx;
  white-space: nowrap;
}

.dynamic {
  margin-top: 14rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.95);
  font-size: 24rpx;
  line-height: 1.45;
}

.quick-actions {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.quick-action {
  width: 100%;
  min-width: 0;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0;
  font-size: 25rpx;
  border-radius: var(--radius-ctl);
  overflow: visible;
}

.elder-card .quick-action.primary-btn {
  background: #ffffff;
  color: var(--brand-deep);
  box-shadow: 0 6rpx 16rpx rgba(24, 92, 78, 0.25);
}

.elder-card .quick-action.ghost-btn {
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.switch-strip {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  margin: 12rpx 0 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #C9D4CF;
}

.dot-active {
  width: 34rpx;
  border-radius: 999rpx;
  background: var(--brand);
}

/* ---- 通用面板 ---- */
.panel {
  margin-top: 20rpx;
  padding: 26rpx;
}

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.panel-right {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.link {
  color: var(--brand);
  font-size: 25rpx;
  font-weight: 800;
}

.hint {
  font-size: 23rpx;
  color: var(--faint);
}

.focus-panel,
.weekly-panel,
.care-timeline-panel {
  box-shadow: var(--shadow);
}

.focus-item {
  margin-top: 10rpx;
  padding: 14rpx 18rpx;
  border-radius: var(--radius-ctl);
  background: var(--accent-soft);
  color: #A96324;
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 600;
}

/* ---- 照护动态时间线 ---- */
.care-timeline-item {
  display: grid;
  grid-template-columns: 108rpx minmax(0, 1fr) auto;
  gap: 14rpx;
  align-items: flex-start;
  padding: 18rpx 0;
  border-top: 1rpx solid var(--border);
}

.care-timeline-item:first-of-type {
  border-top: none;
  padding-top: 0;
}

.care-time {
  color: var(--faint);
  font-size: 22rpx;
  line-height: 1.4;
}

.care-main {
  min-width: 0;
}

.care-title-row {
  display: flex;
  gap: 10rpx;
  align-items: center;
  min-width: 0;
}

.care-category {
  flex: 0 0 auto;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 21rpx;
  font-weight: 800;
}

.care-title {
  flex: 1;
  min-width: 0;
  color: var(--ink);
  font-size: 27rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.care-content {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.5;
}

.care-status {
  color: var(--brand);
  font-size: 22rpx;
  font-weight: 800;
  white-space: nowrap;
}

/* ---- 本周简报 ---- */
.weekly-range {
  font-size: 23rpx;
  color: var(--faint);
}

.weekly-text {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--ink);
  line-height: 1.6;
}

.weekly-grid,
.metric-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.weekly-item,
.metric-item {
  padding: 16rpx 8rpx;
  border-radius: 14rpx;
  background: var(--brand-soft);
  text-align: center;
}

.weekly-item .n {
  display: block;
  font-size: 38rpx;
  color: var(--accent);
  font-weight: 900;
}

.weekly-item .l {
  display: block;
  margin-top: 4rpx;
  font-size: 21rpx;
  color: var(--muted);
}

/* ---- 今日健康摘要（数值醒目） ---- */
.summary-line {
  margin-bottom: 14rpx;
  font-size: 27rpx;
  line-height: 1.5;
  font-weight: 700;
}

.txt-normal { color: var(--success); }
.txt-warning { color: #A9741F; }
.txt-danger { color: var(--danger); }

.metric-grid {
  grid-template-columns: 1fr 1fr;
}

.metric-item {
  text-align: left;
  padding: 18rpx 20rpx;
  background: var(--brand-soft);
}

.metric-name,
.metric-status,
.metric-trend,
.metric-unit {
  font-size: 23rpx;
  color: var(--muted);
}

.metric-value {
  display: block;
  margin-top: 4rpx;
  font-size: 42rpx;
  line-height: 1.25;
  color: var(--accent);
  font-weight: 900;
}

.metric-status,
.metric-trend {
  display: block;
  margin-top: 4rpx;
}

.advice {
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: var(--radius-ctl);
  background: var(--brand-soft);
  color: var(--brand-deep);
  font-size: 25rpx;
  line-height: 1.55;
}

/* ---- 今日日程 ---- */
.timeline-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.timeline-item:last-child {
  border-bottom: none;
}

.time {
  width: 92rpx;
  color: var(--faint);
  font-size: 25rpx;
}

.timeline-main {
  flex: 1;
  min-width: 0;
}

.name {
  display: block;
  font-size: 28rpx;
  color: var(--ink);
  font-weight: 800;
}

.type {
  display: block;
  margin-top: 4rpx;
  font-size: 23rpx;
  color: var(--muted);
}

.state {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.todo { color: var(--muted); background: #EFF2EE; }
.doing { color: var(--info); background: #EDF4F9; }
.done { color: var(--success); background: #E7F4EC; }

/* ---- 今日膳食 ---- */
.meal-review,
.meal-label {
  color: var(--ink);
  font-size: 26rpx;
  line-height: 1.55;
}

.tag-row {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.meal-tag {
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 23rpx;
  font-weight: 700;
}

.meal-list {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* ---- 消息提醒 ---- */
.notice-item {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-main {
  flex: 1;
  min-width: 0;
}

.notice-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
}

.notice-title.urgent { color: var(--danger); }
.notice-title.warning { color: #A9741F; }
.notice-title.normal { color: var(--ink); }

.notice-content {
  display: block;
  margin-top: 6rpx;
  font-size: 25rpx;
  color: var(--muted);
  line-height: 1.5;
}

.notice-side {
  width: 104rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.notice-time {
  font-size: 22rpx;
  color: var(--faint);
}

.unread {
  margin-top: 10rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 0 6rpx rgba(229, 138, 58, 0.16);
}

/* ---- 常用功能（大格子，易点） ---- */
.entry-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.entry-item {
  position: relative;
  min-height: 136rpx;
  padding: 22rpx 16rpx;
  border-radius: 16rpx;
  background: #FAFAF7;
  border: 1rpx solid var(--border);
}

.entry-item:active {
  background: var(--brand-soft);
  transform: translateY(2rpx);
}

.entry-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  min-width: 32rpx;
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
  background: var(--danger);
  color: #ffffff;
  font-size: 19rpx;
  line-height: 1.4;
  text-align: center;
  font-weight: 700;
}

.entry-title {
  display: block;
  font-size: 28rpx;
  color: var(--ink);
  font-weight: 800;
}

.entry-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: var(--muted);
  line-height: 1.4;
}

/* 位置/动态等含编码的长文本：允许任意断行，防止撑破卡片 */
.dynamic,
.care-content,
.focus-value,
.elder-room {
  word-break: break-all;
}
