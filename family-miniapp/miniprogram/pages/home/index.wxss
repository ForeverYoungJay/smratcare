.home-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.runtime-tip {
  margin-bottom: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, rgba(238, 246, 255, 0.96), rgba(247, 250, 255, 0.94));
  border: 1rpx solid rgba(96, 165, 250, 0.18);
  color: #2159ba;
  font-size: 22rpx;
  line-height: 1.6;
}

.state-card {
  margin-bottom: 18rpx;
  padding: 28rpx 24rpx;
}

.state-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.state-btn {
  margin-top: 18rpx;
}

.mini-btn {
  background: rgba(236, 245, 246, 0.94);
  color: #194f5e;
  border-radius: 999rpx;
  font-size: 24rpx;
  padding: 0 24rpx;
  line-height: 64rpx;
  height: 64rpx;
  border: 1rpx solid rgba(44, 122, 132, 0.14);
  flex-shrink: 0;
}

.switch-panel {
  margin-bottom: 18rpx;
  padding: 22rpx 20rpx;
  background:
    radial-gradient(circle at top right, rgba(240, 199, 135, 0.18) 0%, rgba(240, 199, 135, 0) 32%),
    linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(243, 250, 251, 0.94));
}

.switch-label {
  font-size: 22rpx;
  color: #6b7280;
}

.switch-pick {
  margin-top: 10rpx;
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(44, 122, 132, 0.15);
  color: #1f2937;
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.96);
}

.elder-swiper {
  height: 540rpx;
}

.elder-card {
  padding: 28rpx 24rpx;
  min-height: 508rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 251, 252, 0.92));
}

.card-top {
  display: flex;
  gap: 22rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, #194f5e, #2c7a84);
  color: #fff;
  font-size: 38rpx;
  font-weight: 700;
}

.basic {
  flex: 1;
}

.name-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.elder-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  flex: 1;
}

.meta {
  margin-top: 8rpx;
  color: #556273;
  font-size: 23rpx;
  line-height: 1.6;
}

.special-row {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.special-tag {
  background: rgba(255, 243, 230, 0.94);
  color: #c2410c;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.update {
  color: #6b7280;
  font-size: 22rpx;
}

.dynamic {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #374151;
  line-height: 1.7;
  background: rgba(246, 249, 251, 0.92);
  border-radius: 16rpx;
  padding: 16rpx;
}

.quick-actions {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.quick-action {
  flex: 1 1 30%;
  font-size: 24rpx;
  min-width: 180rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
}

.switch-strip {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  margin: 14rpx 0 10rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #cdd5df;
}

.dot-active {
  background: #2c7a84;
  width: 36rpx;
  border-radius: 12rpx;
}

.panel {
  margin-top: 20rpx;
  padding: 26rpx 22rpx;
}

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 14rpx;
  gap: 14rpx;
}

.panel-right {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.link,
.hint {
  font-size: 22rpx;
}

.link {
  color: #1e6770;
}

.hint {
  color: #6b7280;
}

.focus-panel {
  background: linear-gradient(145deg, rgba(255, 250, 243, 0.98), rgba(255, 255, 255, 0.94));
}

.focus-item {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #92400e;
  background: rgba(255, 247, 237, 0.96);
  border-radius: 14rpx;
  padding: 12rpx 14rpx;
  line-height: 1.6;
}

.weekly-panel {
  background: linear-gradient(145deg, rgba(241, 248, 255, 0.98), rgba(255, 255, 255, 0.96));
}

.weekly-range {
  font-size: 22rpx;
  color: #64748b;
}

.weekly-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #334155;
  line-height: 1.5;
}

.weekly-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.weekly-item {
  background: rgba(248, 251, 255, 0.96);
  border: 1rpx solid rgba(191, 219, 254, 0.45);
  border-radius: 16rpx;
  padding: 14rpx 10rpx;
  text-align: center;
}

.weekly-item .n {
  display: block;
  font-size: 30rpx;
  color: #1f2937;
  font-weight: 700;
}

.weekly-item .l {
  display: block;
  font-size: 20rpx;
  color: #64748b;
}

.summary-line {
  font-size: 24rpx;
  margin-bottom: 14rpx;
  line-height: 1.6;
}

.txt-normal {
  color: #0f766e;
}

.txt-warning {
  color: #b45309;
}

.txt-danger {
  color: #b91c1c;
}

.metric-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.metric-item {
  background: rgba(248, 250, 252, 0.96);
  border-radius: 18rpx;
  padding: 16rpx 14rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.68);
}

.metric-name,
.metric-status,
.metric-trend,
.metric-unit {
  font-size: 22rpx;
}

.metric-name {
  color: #6b7280;
}

.metric-value {
  font-size: 34rpx;
  color: #111827;
  font-weight: 700;
  display: block;
  margin-top: 4rpx;
}

.metric-unit,
.metric-status,
.metric-trend {
  color: #4b5563;
  display: block;
  margin-top: 2rpx;
}

.advice {
  margin-top: 14rpx;
  background: rgba(238, 247, 248, 0.96);
  border-radius: 16rpx;
  padding: 14rpx 14rpx;
  color: #1f4f57;
  font-size: 23rpx;
  line-height: 1.7;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed #e5e7eb;
  gap: 12rpx;
}

.timeline-item:last-child {
  border-bottom: none;
}

.time {
  width: 82rpx;
  color: #6b7280;
  font-size: 24rpx;
  flex-shrink: 0;
}

.timeline-main {
  flex: 1;
}

.name {
  font-size: 27rpx;
  color: #111827;
  line-height: 1.5;
}

.type {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #6b7280;
  display: block;
}

.state {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.todo {
  color: #6b7280;
  background: #f1f5f9;
}

.doing {
  color: #1d4ed8;
  background: #eaf1ff;
}

.done {
  color: #0f766e;
  background: #e7f8ef;
}

.meal-review {
  color: #374151;
  font-size: 24rpx;
  line-height: 1.7;
}

.tag-row {
  margin-top: 10rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.meal-tag {
  background: #eef7f8;
  color: #1f4f57;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.meal-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.meal-label {
  color: #374151;
  font-size: 24rpx;
}

.notice-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eef2f7;
  gap: 12rpx;
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-main {
  flex: 1;
  padding-right: 10rpx;
}

.notice-title {
  font-size: 26rpx;
  font-weight: 700;
  display: block;
}

.notice-title.urgent {
  color: #b91c1c;
}

.notice-title.warning {
  color: #b45309;
}

.notice-title.normal {
  color: #1f2937;
}

.notice-content {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #4b5563;
  display: block;
}

.notice-side {
  width: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.notice-time {
  font-size: 22rpx;
  color: #6b7280;
  white-space: nowrap;
}

.unread {
  margin-top: 8rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #e11d48;
}

.entry-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.entry-item {
  position: relative;
  background: rgba(248, 250, 252, 0.96);
  border-radius: 18rpx;
  padding: 20rpx 16rpx 18rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.72);
  min-height: 128rpx;
}

.entry-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 30rpx;
  padding: 2rpx 8rpx;
  border-radius: 999rpx;
  background: #dc2626;
  color: #fff;
  font-size: 18rpx;
  line-height: 1.4;
  text-align: center;
}

.entry-title {
  display: block;
  font-size: 26rpx;
  color: #111827;
  font-weight: 600;
  line-height: 1.4;
}

.entry-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #6b7280;
  line-height: 1.5;
}

@media screen and (max-width: 360px) {
  .home-head {
    flex-direction: column;
    align-items: stretch;
  }

  .mini-btn {
    width: 100%;
  }

  .elder-swiper {
    height: 620rpx;
  }

  .card-top,
  .special-row {
    flex-direction: column;
  }

  .name-row {
    flex-direction: column;
  }

  .metric-grid,
  .entry-grid,
  .weekly-grid {
    grid-template-columns: 1fr;
  }

  .panel-head {
    flex-direction: column;
  }

  .panel-right {
    justify-content: flex-start;
  }

  .quick-action {
    flex-basis: 100%;
  }
}
