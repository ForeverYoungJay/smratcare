.home-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin: 6rpx 0 22rpx;
}

.mini-btn {
  height: 58rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #cddbd6;
  color: #246b5f;
  font-size: 23rpx;
  font-weight: 800;
}

.switch-panel {
  margin-bottom: 18rpx;
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: none;
}

.switch-label {
  font-size: 22rpx;
  color: #73827c;
}

.switch-pick {
  min-width: 360rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #edf6f2;
  color: #1f5f55;
  font-size: 25rpx;
  font-weight: 800;
  text-align: center;
}

.elder-swiper {
  height: 520rpx;
}

.elder-card {
  min-height: 494rpx;
  height: auto;
  padding: 26rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(36, 107, 95, 0.12), rgba(255, 255, 255, 0) 48%),
    #ffffff;
}

.card-top {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex: 0 0 88rpx;
  background: #246b5f;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
}

.basic {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
}

.elder-name {
  flex: 1;
  min-width: 0;
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #16231f;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta {
  margin-top: 6rpx;
  color: #586862;
  font-size: 23rpx;
  line-height: 1.35;
}

.special-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.special-tag {
  max-width: 370rpx;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  background: #fff4df;
  color: #995c07;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.update {
  color: #7b8984;
  font-size: 21rpx;
  white-space: nowrap;
}

.dynamic {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #f5f8f6;
  color: #34443f;
  font-size: 23rpx;
  line-height: 1.45;
}

.quick-actions {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.quick-action {
  width: 100%;
  min-width: 0;
  height: 66rpx;
  line-height: 66rpx;
  padding: 0;
  font-size: 24rpx;
  border-radius: 12rpx;
  overflow: visible;
}

.switch-strip {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  margin: 10rpx 0 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #c7d2cd;
}

.dot-active {
  width: 34rpx;
  border-radius: 999rpx;
  background: #246b5f;
}

.panel {
  margin-top: 18rpx;
  padding: 24rpx;
}

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.panel-right {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.link {
  color: #246b5f;
  font-size: 23rpx;
  font-weight: 800;
}

.hint {
  font-size: 22rpx;
  color: #7a8983;
}

.focus-panel,
.weekly-panel {
  box-shadow: none;
}

.focus-item {
  margin-top: 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  background: #fff8e8;
  color: #8a5508;
  font-size: 24rpx;
  line-height: 1.45;
}

.weekly-range {
  font-size: 22rpx;
  color: #71807a;
}

.weekly-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #34443f;
  line-height: 1.55;
}

.weekly-grid,
.metric-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.weekly-item,
.metric-item {
  padding: 14rpx 8rpx;
  border-radius: 14rpx;
  background: #f5f8f6;
  text-align: center;
}

.weekly-item .n {
  display: block;
  font-size: 32rpx;
  color: #16231f;
  font-weight: 900;
}

.weekly-item .l {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #74827d;
}

.summary-line {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.txt-normal { color: #16704f; }
.txt-warning { color: #9a5b05; }
.txt-danger { color: #b42318; }

.metric-grid {
  grid-template-columns: 1fr 1fr;
}

.metric-item {
  text-align: left;
  padding: 16rpx;
}

.metric-name,
.metric-status,
.metric-trend,
.metric-unit {
  font-size: 22rpx;
  color: #71807a;
}

.metric-value {
  display: block;
  margin-top: 4rpx;
  font-size: 34rpx;
  color: #16231f;
  font-weight: 900;
}

.metric-status,
.metric-trend {
  display: block;
  margin-top: 3rpx;
}

.advice {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #eef7f2;
  color: #245c50;
  font-size: 23rpx;
  line-height: 1.5;
}

.timeline-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #edf2ef;
}

.timeline-item:last-child {
  border-bottom: none;
}

.time {
  width: 88rpx;
  color: #71807a;
  font-size: 24rpx;
}

.timeline-main {
  flex: 1;
  min-width: 0;
}

.name {
  display: block;
  font-size: 26rpx;
  color: #182420;
  font-weight: 800;
}

.type {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #73827c;
}

.state {
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
}

.todo { color: #73827c; background: #edf2ef; }
.doing { color: #255a91; background: #eaf3ff; }
.done { color: #16704f; background: #e5f5ef; }

.meal-review,
.meal-label {
  color: #34443f;
  font-size: 24rpx;
  line-height: 1.5;
}

.tag-row {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.meal-tag {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: #eef7f2;
  color: #246b5f;
  font-size: 22rpx;
}

.meal-list {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.notice-item {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #edf2ef;
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-main {
  flex: 1;
  min-width: 0;
}

.notice-title {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
}

.notice-title.urgent { color: #b42318; }
.notice-title.warning { color: #9a5b05; }
.notice-title.normal { color: #182420; }

.notice-content {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #586862;
  line-height: 1.45;
}

.notice-side {
  width: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.notice-time {
  font-size: 21rpx;
  color: #7a8983;
}

.unread {
  margin-top: 8rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #e5484d;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.entry-item {
  position: relative;
  min-height: 118rpx;
  padding: 16rpx 14rpx;
  border-radius: 16rpx;
  background: #f7faf8;
  border: 1rpx solid #edf2ef;
}

.entry-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 30rpx;
  padding: 2rpx 8rpx;
  border-radius: 999rpx;
  background: #e5484d;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1.4;
  text-align: center;
}

.entry-title {
  display: block;
  font-size: 25rpx;
  color: #182420;
  font-weight: 900;
}

.entry-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #71807a;
  line-height: 1.35;
}
