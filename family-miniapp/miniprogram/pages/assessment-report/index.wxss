.card { padding: 24rpx; }
.ai-row { margin-top: 10rpx; display: flex; gap: 10rpx; flex-wrap: wrap; }
.ai-btn { height: 58rpx; line-height: 58rpx; padding: 0 16rpx; font-size: 22rpx; }
.item { margin-top: 14rpx; padding: 16rpx; border: 1rpx solid #e5edf2; border-radius: 12rpx; background: #f8fafc; }
.name { font-size: 28rpx; color: #111827; font-weight: 700; }
.meta { margin-top: 6rpx; font-size: 22rpx; color: #6b7280; }
.summary { margin-top: 8rpx; font-size: 23rpx; color: #374151; }
.score { margin-top: 8rpx; font-size: 23rpx; color: #92400e; }
.action { margin-top: 12rpx; height: 60rpx; line-height: 60rpx; font-size: 22rpx; }
