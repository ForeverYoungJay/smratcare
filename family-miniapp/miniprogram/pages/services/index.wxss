.block {
  padding: 24rpx;
}

.entry-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.entry {
  background: #f8fafc;
  border: 1rpx solid #e5edf2;
  border-radius: 16rpx;
  padding: 18rpx;
}

.title {
  display: block;
  font-size: 28rpx;
  color: #111827;
  font-weight: 700;
}

.desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.5;
}
