/* ===== 服务页 · 入口卡片清晰易点 ===== */

.block {
  padding: 28rpx;
}

.entry-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
}

.entry {
  position: relative;
  min-height: 132rpx;
  padding: 26rpx 60rpx 26rpx 124rpx;
  border-radius: var(--radius-card);
  background: #ffffff;
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow);
}

.entry:active {
  background: var(--brand-soft);
}

.entry::before {
  content: attr(data-icon);
  position: absolute;
  left: 26rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 76rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #21705F, #2E8A72);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
  text-align: center;
  box-shadow: 0 6rpx 14rpx rgba(33, 112, 95, 0.22);
}

.entry::after {
  content: '';
  position: absolute;
  right: 26rpx;
  top: 50%;
  width: 16rpx;
  height: 16rpx;
  border-top: 4rpx solid var(--faint);
  border-right: 4rpx solid var(--faint);
  transform: translateY(-50%) rotate(45deg);
}

.title {
  display: block;
  font-size: 31rpx;
  line-height: 1.3;
  color: var(--ink);
  font-weight: 800;
}

.desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--muted);
  line-height: 1.5;
}
