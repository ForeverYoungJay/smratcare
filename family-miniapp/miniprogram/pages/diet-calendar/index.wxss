.card { padding: 24rpx; }
.item { margin-top: 14rpx; background: #f8fafc; border-radius: 12rpx; border: 1rpx solid #e5edf2; padding: 14rpx; }
.date { font-size: 26rpx; color: #111827; font-weight: 700; }
.review { margin-top: 8rpx; font-size: 22rpx; color: #4b5563; }
.meal { margin-top: 6rpx; font-size: 23rpx; color: #374151; }
.photo-empty { margin-top: 8rpx; font-size: 21rpx; color: #94a3b8; }
.photo-row { margin-top: 8rpx; display: flex; gap: 10rpx; flex-wrap: wrap; }
.photo { width: 160rpx; height: 120rpx; border-radius: 10rpx; background: #e2e8f0; }
