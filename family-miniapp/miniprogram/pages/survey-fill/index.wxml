<view class="container">
  <view class="surface card">
    <view class="section-title">满意度问卷</view>
    <view wx:if="{{loading}}" class="empty-tip"><text>问卷加载中...</text></view>
    <view wx:if="{{!loading && !surveys.length}}" class="empty-tip">
      <text class="empty-main">当前暂无进行中的问卷</text>
      <text class="empty-sub">机构发布月度满意度调查后会第一时间在这里出现</text>
    </view>
    <block wx:for="{{surveys}}" wx:key="id" wx:for-item="survey">
      <view class="survey-item {{survey.id === activeId ? 'active' : ''}}" data-id="{{survey.id}}" bindtap="openSurvey">
        <view class="survey-name">{{survey.name}}</view>
        <view class="survey-meta">
          <text wx:if="{{survey.anonymous}}" class="pill">匿名</text>
          <text class="pill {{survey.submitted ? 'done' : 'todo'}}">{{survey.submitted ? '已提交' : '待填写'}}</text>
        </view>
        <view wx:if="{{survey.description}}" class="survey-desc">{{survey.description}}</view>
      </view>
    </block>
  </view>

  <block wx:for="{{surveys}}" wx:key="id" wx:for-item="survey">
    <view wx:if="{{survey.id === activeId && !survey.submitted}}" class="surface card">
      <block wx:for="{{survey.questions}}" wx:key="id" wx:for-item="q" wx:for-index="qIndex">
        <view class="question">
          <view class="q-title">{{qIndex + 1}}. {{q.title}} <text wx:if="{{q.required}}" class="required">*</text></view>
          <view wx:if="{{q.options.length}}" class="options">
            <view
              wx:for="{{q.options}}"
              wx:key="*this"
              wx:for-item="option"
              class="option {{answers[q.id] === option ? 'selected' : ''}}"
              data-qid="{{q.id}}"
              data-option="{{option}}"
              bindtap="chooseOption">{{option}}</view>
          </view>
          <textarea wx:else class="text-answer" placeholder="请输入您的意见与建议" data-qid="{{q.id}}" value="{{answers[q.id] || ''}}" bindinput="onTextInput" />
        </view>
      </block>
      <button class="primary-btn" loading="{{submitting}}" bindtap="submit">提交问卷</button>
    </view>
  </block>
</view>
