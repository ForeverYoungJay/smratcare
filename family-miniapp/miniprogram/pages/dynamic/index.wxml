<view class="container">
  <view class="page-head">
    <view class="section-title">长者动态中心</view>
    <view class="section-subtitle">一处汇总长者的照护、健康与生活动态</view>
  </view>

  <view class="grid">
    <view class="grid-item surface" wx:for="{{entries}}" wx:key="path" data-path="{{item.path}}" bindtap="go">
      <view class="grid-icon">{{item.icon}}</view>
      <view class="grid-name">{{item.name}}</view>
      <view class="grid-desc">{{item.desc}}</view>
    </view>
  </view>
</view>
