.form-card {
  margin-top: 22rpx;
  padding: 26rpx;
}

.field {
  margin-top: 22rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #60716b;
  font-size: 23rpx;
  font-weight: 850;
}

.picker-line,
.input-line,
.textarea-line {
  width: 100%;
  border-radius: 14rpx;
  border: 1rpx solid #d9e3df;
  background: #ffffff;
  color: #182420;
  font-size: 25rpx;
}

.picker-line,
.input-line {
  min-height: 74rpx;
  line-height: 74rpx;
  padding: 0 18rpx;
}

.textarea-line {
  min-height: 180rpx;
  padding: 18rpx;
  line-height: 1.55;
}

.field-hint {
  margin-top: 8rpx;
  text-align: right;
  color: #8a9691;
  font-size: 21rpx;
}

.submit-btn {
  width: 100%;
  margin-top: 24rpx;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  margin: 22rpx 0 0;
  padding-bottom: 4rpx;
}

.filter {
  flex: 0 0 auto;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #edf2f0;
  color: #62716b;
  font-size: 24rpx;
  font-weight: 850;
}

.filter.active {
  background: #246b5f;
  color: #ffffff;
}

.retry-btn {
  margin-top: 20rpx;
}

.empty-card {
  margin-top: 18rpx;
  padding: 34rpx;
}

.suggestion-card {
  margin-top: 18rpx;
  padding: 26rpx;
}

.suggestion-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.suggestion-title {
  color: #182430;
  font-size: 30rpx;
  font-weight: 900;
}

.suggestion-meta {
  margin-top: 8rpx;
  color: #73808c;
  font-size: 22rpx;
}

.status-pill {
  flex: none;
  height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #fff2d9;
  color: #9a5b05;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 46rpx;
}

.status-PROCESSING {
  background: #eef6ff;
  color: #255a91;
}

.status-DONE {
  background: #e5f5ef;
  color: #16704f;
}

.status-CLOSED {
  background: #edf2f0;
  color: #62716b;
}

.suggestion-content {
  margin-top: 16rpx;
  color: #465563;
  font-size: 25rpx;
  line-height: 1.65;
}

.reply-box {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f3f8f6;
  border: 1rpx solid #dcebe5;
}

.reply-label {
  color: #246b5f;
  font-size: 22rpx;
  font-weight: 900;
}

.reply-content {
  margin-top: 8rpx;
  color: #34434c;
  font-size: 24rpx;
  line-height: 1.55;
}
