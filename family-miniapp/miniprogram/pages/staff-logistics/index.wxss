.quick-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin: 18rpx 0;
}

.quick-btn {
  width: 100%;
}

.work-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #edf1f5;
}
.work-row:first-of-type { border-top: 0; }
.work-title { color: #182430; font-size: 28rpx; font-weight: 900; }
.work-meta { margin-top: 8rpx; color: #73808c; font-size: 23rpx; }
.work-action { color: #1f5f8b; font-size: 24rpx; font-weight: 900; white-space: nowrap; }
