.card { padding: 24rpx; }
.review { margin-top: 12rpx; font-size: 24rpx; color: #374151; line-height: 1.6; }
.tag-row { margin-top: 10rpx; display: flex; gap: 10rpx; flex-wrap: wrap; }
.tag { background: #eef7f8; color: #1f4f57; padding: 6rpx 12rpx; border-radius: 999rpx; font-size: 22rpx; }
.meal { margin-top: 12rpx; background: #f8fafc; border-radius: 12rpx; padding: 14rpx; font-size: 24rpx; color: #111827; }
.label { color: #6b7280; }
.photo-empty { margin-top: 8rpx; font-size: 22rpx; color: #94a3b8; }
.photo-row { margin-top: 8rpx; display: flex; gap: 10rpx; flex-wrap: wrap; }
.photo { width: 180rpx; height: 130rpx; border-radius: 10rpx; background: #e2e8f0; }
