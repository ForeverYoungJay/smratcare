.card { padding: 24rpx; }
.line { margin-top: 12rpx; font-size: 24rpx; color: #34443f; }
.field { margin-top: 14rpx; }
.label { display: block; font-size: 22rpx; color: #5C6F69; margin-bottom: 8rpx; }
.input { background: #FAFAF7; border: 1rpx solid #dbe3ea; border-radius: 10rpx; padding: 14rpx; font-size: 24rpx; }
.textarea { margin-top: 14rpx; min-height: 180rpx; background: #FAFAF7; border: 1rpx solid #dbe3ea; border-radius: 14rpx; padding: 20rpx; font-size: 26rpx; }
.action { margin-top: 18rpx; }
.record-empty { margin-top: 10rpx; font-size: 22rpx; color: #94a3b8; }
.record { margin-top: 10rpx; padding: 14rpx; border: 1rpx solid #E4E7E0; border-radius: 10rpx; background: #FAFAF7; }
.record-title { font-size: 24rpx; color: #22332E; font-weight: 600; }
.record-meta { margin-top: 6rpx; font-size: 21rpx; color: #5C6F69; }
.record-content { margin-top: 6rpx; font-size: 23rpx; color: #334155; }
.record-reply { margin-top: 6rpx; font-size: 22rpx; color: #21705F; }
