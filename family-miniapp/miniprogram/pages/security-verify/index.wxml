<view class="container">
  <view class="surface card">
    <view class="section-title">{{title}}</view>
    <view class="section-subtitle">为保护老人隐私，请再次输入登录密码。验证通过后 10 分钟内免重复验证。</view>

    <view class="code-box">
      <view class="label">登录密码</view>
      <input
        class="code-input"
        type="password"
        maxlength="32"
        placeholder="请输入登录密码"
        value="{{password}}"
        bindinput="onPasswordInput" />
    </view>

    <view class="action-row">
      <button class="primary-btn action-btn" loading="{{submitting}}" bindtap="submitVerify">验证并继续</button>
    </view>
  </view>
</view>
