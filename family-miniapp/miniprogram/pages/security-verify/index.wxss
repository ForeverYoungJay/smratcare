.card {
  padding: 26rpx;
  margin-top: 80rpx;
}

.code-box {
  margin-top: 20rpx;
  border-radius: 14rpx;
  border: 1rpx solid #d6e1e6;
  background: #f8fafc;
  padding: 16rpx;
}

.label {
  font-size: 23rpx;
  color: #556273;
}

.code-input {
  margin-top: 10rpx;
  border-radius: 12rpx;
  border: 1rpx solid #cbd5df;
  background: #fff;
  padding: 14rpx 16rpx;
  font-size: 30rpx;
  letter-spacing: 4rpx;
}

.hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748b;
}

.action-row {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  font-size: 25rpx;
}

.switch-btn {
  margin-top: 14rpx;
  width: 100%;
  height: 62rpx;
  line-height: 62rpx;
  font-size: 22rpx;
}
