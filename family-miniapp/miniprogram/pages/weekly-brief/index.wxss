.hero {
  padding: 24rpx;
  background: linear-gradient(145deg, #f4fbff, #ffffff);
}

.hero.overall-warning {
  background: linear-gradient(145deg, #fff7eb, #ffffff);
}

.hero.overall-danger {
  background: linear-gradient(145deg, #fff1f1, #ffffff);
}

.hero-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 14rpx;
}

.status-pill {
  font-size: 22rpx;
  color: #b45309;
  background: #fff4e8;
  border: 1rpx solid #f2c48b;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
}

.overall-text {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #374151;
  line-height: 1.6;
}

.stat-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.stat-item {
  background: #f8fbfd;
  border: 1rpx solid #e3edf2;
  border-radius: 12rpx;
  padding: 10rpx 8rpx;
  text-align: center;
}

.stat-item .num {
  display: block;
  font-size: 34rpx;
  color: #1f2937;
  font-weight: 700;
}

.stat-item .txt {
  display: block;
  margin-top: 2rpx;
  font-size: 21rpx;
  color: #64748b;
}

.panel {
  margin-top: 18rpx;
  padding: 22rpx;
}

.panel-title {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 700;
}

.vital-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.vital-item {
  border-radius: 12rpx;
  border: 1rpx solid #e2e8f0;
  background: #f9fbfc;
  padding: 12rpx;
}

.vital-name {
  font-size: 22rpx;
  color: #64748b;
}

.vital-value {
  margin-top: 6rpx;
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 700;
}

.vital-status {
  margin-top: 8rpx;
  display: inline-block;
  padding: 3rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.badge-normal {
  color: #0f766e;
  background: #e9f9ef;
}

.badge-warning {
  color: #b45309;
  background: #fff4e8;
}

.badge-danger {
  color: #b91c1c;
  background: #fef2f2;
}

.line-item {
  margin-top: 10rpx;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.dot {
  margin-top: 2rpx;
  color: #2c7a84;
  font-size: 24rpx;
}

.line-text {
  flex: 1;
  font-size: 23rpx;
  color: #334155;
  line-height: 1.6;
}

.suggest-item {
  margin-top: 10rpx;
  border-radius: 10rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  padding: 10rpx 12rpx;
  font-size: 23rpx;
  color: #334155;
  line-height: 1.6;
}

.history-item {
  margin-top: 10rpx;
  border-radius: 10rpx;
  border: 1rpx solid #e2e8f0;
  background: #f8fafc;
  padding: 10rpx 12rpx;
}

.history-item.overall-warning {
  background: #fffaf1;
  border-color: #f2d6a2;
}

.history-item.overall-danger {
  background: #fff1f1;
  border-color: #f5c2c2;
}

.history-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-range {
  font-size: 23rpx;
  color: #1f2937;
  font-weight: 700;
}

.history-level {
  font-size: 21rpx;
  color: #64748b;
}

.history-quick {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #334155;
}

.quick-actions {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.action-btn {
  width: 100%;
}
