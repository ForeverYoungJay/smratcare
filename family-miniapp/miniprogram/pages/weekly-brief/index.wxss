.hero {
  padding: 28rpx;
  background:
    linear-gradient(135deg, rgba(33, 112, 95, 0.13), rgba(255, 255, 255, 0) 52%),
    #ffffff;
}

.hero.overall-warning {
  background:
    linear-gradient(135deg, rgba(245, 158, 11, 0.16), rgba(255, 255, 255, 0) 52%),
    #ffffff;
}

.hero.overall-danger {
  background:
    linear-gradient(135deg, rgba(180, 35, 24, 0.14), rgba(255, 255, 255, 0) 52%),
    #ffffff;
}

.hero-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.status-pill {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #fff4df;
  color: #B27221;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
}

.overall-text {
  margin-top: 16rpx;
  font-size: 25rpx;
  color: #34443f;
  line-height: 1.65;
}

.stat-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.stat-item {
  padding: 14rpx 8rpx;
  border-radius: 14rpx;
  background: #FAFAF7;
  text-align: center;
}

.stat-item .num {
  display: block;
  font-size: 34rpx;
  color: #22332E;
  font-weight: 900;
}

.stat-item .txt {
  display: block;
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #5C6F69;
}

.panel {
  margin-top: 18rpx;
  padding: 24rpx;
}

.vital-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.vital-item {
  padding: 16rpx;
  border-radius: 16rpx;
  background: #FAFAF7;
  border: 1rpx solid #E4E7E0;
}

.vital-name {
  font-size: 22rpx;
  color: #5C6F69;
}

.vital-value {
  margin-top: 6rpx;
  font-size: 28rpx;
  color: #22332E;
  font-weight: 900;
}

.vital-status {
  display: inline-block;
  margin-top: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
}

.badge-normal { color: #21705F; background: #E8F3EF; }
.badge-warning { color: #B27221; background: #fff4df; }
.badge-danger { color: #C9504B; background: #F9E7E6; }

.line-item {
  margin-top: 12rpx;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.dot {
  margin-top: 2rpx;
  color: #21705F;
  font-size: 24rpx;
}

.line-text {
  flex: 1;
  font-size: 24rpx;
  color: #34443f;
  line-height: 1.6;
}

.suggest-item {
  margin-top: 10rpx;
  padding: 13rpx 14rpx;
  border-radius: 14rpx;
  background: #FAFAF7;
  font-size: 23rpx;
  color: #34443f;
  line-height: 1.6;
}

.history-item {
  margin-top: 12rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #FAFAF7;
  border: 1rpx solid #E4E7E0;
}

.history-item.overall-warning {
  background: #fff9ed;
  border-color: #f1d4a6;
}

.history-item.overall-danger {
  background: #fff4f2;
  border-color: #f0c2bd;
}

.history-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
}

.history-range {
  flex: 1;
  min-width: 0;
  font-size: 23rpx;
  color: #22332E;
  font-weight: 900;
}

.history-level {
  font-size: 21rpx;
  color: #5C6F69;
  white-space: nowrap;
}

.history-quick {
  margin-top: 7rpx;
  font-size: 22rpx;
  color: #52615c;
  line-height: 1.45;
}

.quick-actions {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.action-btn {
  width: 100%;
}
