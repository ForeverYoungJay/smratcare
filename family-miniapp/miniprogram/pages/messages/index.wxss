.board {
  padding: 26rpx;
  overflow: hidden;
}

.top-row {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 14rpx;
}

.intro-col {
  width: 100%;
}

.op-col {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx;
  width: 100%;
}

.mini-read-btn {
  height: 56rpx;
  line-height: 56rpx;
  font-size: 22rpx;
  border-radius: 999rpx;
  padding: 0 18rpx;
  min-width: 0;
  margin: 0;
  width: 100%;
  box-sizing: border-box;
}

.unread-summary {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #fff7ed, #fffaf5);
  color: #9a3412;
  font-size: 22rpx;
  line-height: 1.7;
  border: 1rpx solid #fed7aa;
}

.filter-scroll {
  margin-top: 18rpx;
  width: 100%;
  white-space: nowrap;
  overflow: hidden;
}

.filter-row {
  display: inline-flex;
  gap: 10rpx;
  padding: 4rpx 4rpx 8rpx;
}

.filter-item {
  border-radius: 999rpx;
  border: 1rpx solid #e2e8f0;
  background: #f8fafc;
  color: #475569;
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  line-height: 1;
}

.filter-item-active {
  color: #0f4a5d;
  background: #e8f4f6;
  border-color: #9ec9d1;
  font-weight: 700;
}

.msg-item {
  display: block;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #e5e7eb;
  overflow: hidden;
}

.msg-item:last-child {
  border-bottom: none;
}

.left {
  width: 100%;
  min-width: 0;
}

.badge-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.tag.urgent {
  background: #ffefef;
  color: #b91c1c;
}

.tag.warning {
  background: #fff4e8;
  color: #b45309;
}

.tag.normal {
  background: #eef7f8;
  color: #1f4f57;
}

.type {
  font-size: 20rpx;
  color: #6b7280;
  min-width: 0;
  word-break: break-word;
}

.title {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #111827;
  font-weight: 700;
  line-height: 1.45;
  word-break: break-word;
}

.content,
.meta {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #4b5563;
  line-height: 1.65;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.item-bottom {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.item-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-left: auto;
  max-width: 100%;
}

.contact {
  min-height: 60rpx;
  line-height: 1.35;
  padding: 10rpx 16rpx;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
  margin: 0;
  max-width: 100%;
}

.unread {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ef4444;
  box-shadow: 0 0 0 8rpx rgba(239, 68, 68, 0.12);
}
