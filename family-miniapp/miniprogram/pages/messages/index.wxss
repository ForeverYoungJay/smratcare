.board {
  padding: 28rpx;
  overflow: hidden;
}

.top-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.op-col {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10rpx;
}

.mini-read-btn {
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  padding: 0 18rpx;
  width: 100%;
}

.unread-summary {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #fff7e8;
  color: #8a5508;
  font-size: 22rpx;
  line-height: 1.65;
}

.filter-scroll {
  margin-top: 18rpx;
  width: 100%;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 10rpx;
  padding-bottom: 8rpx;
}

.filter-item {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d9e3df;
  background: #ffffff;
  color: #52615c;
  font-size: 22rpx;
}

.filter-item-active {
  color: #ffffff;
  background: #246b5f;
  border-color: #246b5f;
  font-weight: 900;
}

.msg-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf2ef;
}

.msg-item:last-child {
  border-bottom: none;
}

.left {
  width: 100%;
  min-width: 0;
}

.badge-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
}

.tag.urgent { background: #fde8e5; color: #b42318; }
.tag.warning { background: #fff4df; color: #9a5b05; }
.tag.normal { background: #e5f5ef; color: #16704f; }

.type {
  font-size: 20rpx;
  color: #71807a;
}

.title {
  margin-top: 10rpx;
  font-size: 29rpx;
  color: #182420;
  font-weight: 900;
  line-height: 1.4;
  word-break: break-word;
}

.content,
.meta {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #52615c;
  line-height: 1.6;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.item-bottom {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.item-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-left: auto;
}

.contact {
  min-height: 56rpx;
  line-height: 1.35;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.unread {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #e5484d;
  box-shadow: 0 0 0 8rpx rgba(229, 72, 77, 0.12);
}
