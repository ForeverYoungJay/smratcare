/* ===== 消息列表 · 未读醒目 · 分类清晰 ===== */

.board {
  padding: 28rpx;
  overflow: hidden;
}

.top-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.op-col {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.mini-read-btn {
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  padding: 0 20rpx;
  width: 100%;
}

/* 未读汇总条（暖橙点缀，醒目） */
.unread-summary {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: var(--accent-soft);
  border: 1rpx solid rgba(229, 138, 58, 0.25);
  color: #A96324;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.6;
}

/* ---- 分类筛选 ---- */
.filter-scroll {
  margin-top: 20rpx;
  width: 100%;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 12rpx;
  padding-bottom: 8rpx;
}

.filter-item {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border);
  background: #ffffff;
  color: var(--muted);
  font-size: 25rpx;
}

.filter-item-active {
  color: #ffffff;
  background: linear-gradient(135deg, #21705F, #2E8A72);
  border-color: var(--brand);
  font-weight: 800;
  box-shadow: 0 4rpx 12rpx rgba(33, 112, 95, 0.25);
}

/* ---- 消息条目 ---- */
.msg-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.msg-item:last-child {
  border-bottom: none;
}

.left {
  width: 100%;
  min-width: 0;
}

.badge-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag {
  display: inline-block;
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 800;
}

.tag.urgent { background: #F9E7E6; color: var(--danger); }
.tag.warning { background: var(--accent-soft); color: #A9741F; }
.tag.normal { background: var(--brand-soft); color: var(--brand); }

.type {
  font-size: 22rpx;
  color: var(--faint);
}

.title {
  margin-top: 10rpx;
  font-size: 30rpx;
  color: var(--ink);
  font-weight: 800;
  line-height: 1.4;
  word-break: break-word;
}

.content,
.meta {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--muted);
  line-height: 1.6;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.meta {
  font-size: 23rpx;
  color: var(--faint);
}

.item-bottom {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.item-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: auto;
}

.contact {
  min-height: 60rpx;
  line-height: 1.35;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* 未读点（暖橙，带光晕） */
.unread {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 0 8rpx rgba(229, 138, 58, 0.16);
}

.retry-btn {
  margin-top: 16rpx;
}
