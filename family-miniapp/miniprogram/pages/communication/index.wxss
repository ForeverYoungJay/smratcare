.chat-page {
  min-height: 100vh;
  padding: 0 20rpx 132rpx;
  box-sizing: border-box;
  background: #eef3f1;
}

.runtime-tip {
  margin: 16rpx 0;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  background: #eef6ff;
  border: 1rpx solid #bfdbfe;
  color: #1d4ed8;
  font-size: 22rpx;
  line-height: 1.6;
}

.chat-header {
  position: sticky;
  top: 0;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0 14rpx;
  background: #eef3f1;
}

.chat-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #17211f;
}

.chat-subtitle {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #66756f;
}

.role-state {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #d7e2dd;
  color: #57706a;
  font-size: 21rpx;
  font-weight: 700;
}

.role-tabs {
  white-space: nowrap;
  margin: 2rpx -20rpx 12rpx;
  padding: 0 20rpx 10rpx;
  box-sizing: border-box;
}

.role-tab {
  display: inline-block;
  width: 184rpx;
  height: 92rpx;
  margin-right: 12rpx;
  padding: 17rpx 18rpx 0;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid #d9e5df;
  color: #566b65;
}

.role-tab.active {
  background: #1f7a69;
  border-color: #1f7a69;
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(31, 122, 105, 0.18);
}

.role-tab-title {
  display: block;
  font-size: 25rpx;
  line-height: 1.2;
  font-weight: 800;
}

.role-tab-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 18rpx;
  line-height: 1.2;
  opacity: 0.76;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.error-card {
  margin-bottom: 16rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
}

.error-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #9a3412;
}

.error-text {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #9a3412;
  line-height: 1.5;
}

.retry-btn {
  margin-top: 12rpx;
  height: 58rpx;
  line-height: 58rpx;
  font-size: 23rpx;
}

.message-scroll {
  height: calc(100vh - 342rpx);
  box-sizing: border-box;
  padding-bottom: 18rpx;
}

.loading-text,
.empty-chat {
  margin-top: 120rpx;
  text-align: center;
  color: #7a8983;
  font-size: 24rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #40504b;
  font-weight: 800;
}

.empty-text {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #7a8983;
}

.time-divider {
  width: fit-content;
  max-width: 420rpx;
  margin: 22rpx auto 16rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(111, 127, 121, 0.16);
  color: #71817b;
  font-size: 20rpx;
}

.message-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.message-row.mine {
  flex-direction: row-reverse;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 64rpx;
  background: #ffffff;
  color: #1f6157;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 20rpx rgba(46, 64, 58, 0.08);
}

.mine .avatar {
  background: #1f7a69;
  color: #fff;
}

.bubble-wrap {
  max-width: 560rpx;
  margin-left: 14rpx;
}

.mine .bubble-wrap {
  margin-left: 0;
  margin-right: 14rpx;
  align-items: flex-end;
}

.sender-name {
  margin-bottom: 6rpx;
  font-size: 21rpx;
  color: #75857f;
}

.bubble {
  position: relative;
  padding: 18rpx 20rpx;
  border-radius: 10rpx 22rpx 22rpx 22rpx;
  background: #ffffff;
  color: #1e2926;
  box-shadow: 0 8rpx 20rpx rgba(36, 54, 48, 0.08);
}

.mine .bubble {
  border-radius: 22rpx 10rpx 22rpx 22rpx;
  background: #95e27d;
  box-shadow: none;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-word;
}

.message-status {
  margin-top: 6rpx;
  font-size: 19rpx;
  color: #84918c;
}

.mine .message-status {
  text-align: right;
}

.voice-bubble {
  min-width: 260rpx;
}

.voice-content {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.voice-icon {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  background: #1f7a69;
  box-shadow: 0 0 0 8rpx rgba(31, 122, 105, 0.12);
}

.mine .voice-icon {
  background: #256446;
}

.voice-icon.playing {
  animation: pulse 1s infinite;
}

.wave {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.wave text {
  width: 6rpx;
  border-radius: 999rpx;
  background: #2f6e61;
}

.wave text:nth-child(1) { height: 16rpx; }
.wave text:nth-child(2) { height: 28rpx; }
.wave text:nth-child(3) { height: 38rpx; }
.wave text:nth-child(4) { height: 24rpx; }
.wave text:nth-child(5) { height: 18rpx; }

.voice-duration {
  font-size: 23rpx;
  color: #31534b;
}

.visit-bubble {
  background: #fffaf0;
  border: 1rpx solid #fde68a;
}

.visit-title {
  font-size: 24rpx;
  font-weight: 800;
  color: #92400e;
}

.visit-text {
  margin-top: 6rpx;
  font-size: 25rpx;
  color: #78350f;
  line-height: 1.45;
}

.chat-image {
  display: block;
  width: 280rpx;
  height: 210rpx;
  border-radius: 16rpx;
  background: #dbe5e1;
}

.chat-video {
  display: block;
  width: 360rpx;
  height: 240rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #1f2d29;
}

.chat-bottom {
  height: 42rpx;
}

.visit-panel {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: calc(104rpx + env(safe-area-inset-bottom));
  z-index: 12;
  padding: 22rpx;
  border-radius: 24rpx 24rpx 18rpx 18rpx;
  background: #ffffff;
  border: 1rpx solid #dce8e2;
  box-shadow: 0 18rpx 54rpx rgba(31, 49, 43, 0.18);
}

.tool-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.tool-item {
  flex: 1;
  padding: 0;
  background: #f5faf7;
  border: 1rpx solid #dbe8e2;
  border-radius: 18rpx;
  height: 118rpx;
}

.tool-icon {
  display: block;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  margin: 18rpx auto 8rpx;
  border-radius: 14rpx;
  background: #1f7a69;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.tool-label {
  display: block;
  font-size: 22rpx;
  color: #34443f;
  line-height: 1;
}

.muted-tool .tool-icon {
  background: #e8f1ed;
  color: #1f7a69;
}

.visit-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.visit-panel-title {
  font-size: 27rpx;
  font-weight: 800;
  color: #1f2d29;
}

.visit-panel-subtitle {
  margin-top: 5rpx;
  font-size: 21rpx;
  color: #7a8983;
}

.visit-close {
  width: 52rpx;
  height: 52rpx;
  line-height: 48rpx;
  padding: 0;
  border-radius: 50%;
  background: #f2f6f4;
  color: #6c7d77;
  font-size: 32rpx;
}

.visit-panel-row {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.visit-input {
  flex: 1;
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe5e1;
  font-size: 25rpx;
}

.visit-submit {
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.record-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(10, 18, 15, 0.28);
}

.record-card {
  width: 300rpx;
  padding: 36rpx 24rpx;
  border-radius: 24rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.94);
}

.record-mic {
  width: 76rpx;
  height: 76rpx;
  margin: 0 auto 18rpx;
  border-radius: 50%;
  background: #1f7a69;
  box-shadow: 0 0 0 18rpx rgba(31, 122, 105, 0.12);
}

.record-title {
  font-size: 28rpx;
  color: #15221f;
  font-weight: 800;
}

.record-text {
  margin-top: 8rpx;
  color: #697a74;
  font-size: 22rpx;
}

.composer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 20rpx calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(248, 251, 249, 0.96);
  border-top: 1rpx solid #dce6e1;
}

.icon-btn,
.mode-btn,
.send-btn {
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  padding: 0;
  font-size: 24rpx;
}

.icon-btn {
  width: 68rpx;
  min-width: 68rpx;
  background: #ffffff;
  color: #1f6157;
  border: 1rpx solid #cfddd8;
  font-size: 40rpx;
  font-weight: 300;
}

.mode-btn {
  width: 104rpx;
  min-width: 104rpx;
  background: #ffffff;
  color: #1f6157;
  border: 1rpx solid #cfddd8;
  font-weight: 700;
}

.chat-input,
.hold-voice {
  flex: 1;
  height: 68rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #cfddd8;
  box-sizing: border-box;
}

.chat-input {
  min-width: 0;
  padding: 0 26rpx;
  font-size: 27rpx;
  color: #17211f;
}

.hold-voice {
  line-height: 68rpx;
  color: #24332f;
  font-size: 27rpx;
  font-weight: 700;
}

.hold-voice.recording {
  background: #dff7dc;
  color: #166534;
}

.send-btn {
  width: 100rpx;
  min-width: 100rpx;
  background: #1f7a69;
  color: #fff;
  font-weight: 700;
}

.send-btn[disabled] {
  background: #eef3f1;
  color: #aebbb6;
  border: 1rpx solid #d8e2dd;
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.16); opacity: 0.72; }
  100% { transform: scale(1); opacity: 1; }
}
