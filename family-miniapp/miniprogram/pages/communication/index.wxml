<view class="chat-page">
  <view class="runtime-tip" wx:if="{{runtimeNotice}}">{{runtimeNotice}}</view>

  <view class="chat-header">
    <view>
      <view class="chat-title">在线沟通</view>
      <view class="chat-subtitle">与机构照护团队实时留言</view>
    </view>
    <picker mode="selector" range="{{roleOptions}}" value="{{roleIndex}}" bindchange="onRoleChange">
      <view class="role-pill">{{roleOptions[roleIndex]}}</view>
    </picker>
  </view>

  <view class="error-card" wx:if="{{loadError}}">
    <view class="error-title">沟通暂时不可用</view>
    <view class="error-text">{{loadError}}</view>
    <button class="ghost-btn retry-btn" bindtap="retryLoad">重新加载</button>
  </view>

  <scroll-view
    class="message-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    scroll-into-view="chat-bottom">
    <view wx:if="{{loading}}" class="loading-text">正在同步沟通记录...</view>
    <view wx:if="{{!loading && messages.length === 0}}" class="empty-chat">
      <view class="empty-title">还没有沟通记录</view>
      <view class="empty-text">直接输入文字，或按住说话给照护团队留言。</view>
    </view>

    <block wx:for="{{messages}}" wx:for-item="msg" wx:key="id">
      <view class="time-divider" wx:if="{{msg.showTime}}">{{msg.time}}</view>
      <view class="message-row {{msg.mine ? 'mine' : 'theirs'}}">
        <view class="avatar">{{msg.avatarText}}</view>
        <view class="bubble-wrap">
          <view class="sender-name" wx:if="{{!msg.mine}}">{{msg.targetRole}}</view>
          <view class="bubble {{msg.isVoice ? 'voice-bubble' : ''}} {{msg.isVisit ? 'visit-bubble' : ''}}">
            <block wx:if="{{msg.isVoice}}">
              <view
                class="voice-content"
                data-id="{{msg.idText}}"
                data-url="{{msg.playableUrl}}"
                bindtap="playVoice">
                <view class="voice-icon {{playingId === msg.idText ? 'playing' : ''}}"></view>
                <view class="wave">
                  <text></text><text></text><text></text><text></text><text></text>
                </view>
                <view class="voice-duration">{{msg.voiceDurationText || '语音'}}</view>
              </view>
            </block>
            <block wx:elif="{{msg.isVisit}}">
              <view class="visit-title">探视预约</view>
              <view class="visit-text">{{msg.content}}</view>
            </block>
            <block wx:else>
              <view class="message-text">{{msg.content}}</view>
            </block>
          </view>
          <view class="message-status">{{msg.status}} · {{msg.msgTypeText}}</view>
        </view>
      </view>
    </block>
    <view id="chat-bottom" class="chat-bottom"></view>
  </scroll-view>

  <view class="visit-panel" wx:if="{{showVisitPanel}}">
    <view class="visit-panel-title">预约探视时间</view>
    <view class="visit-panel-row">
      <input class="visit-input" value="{{videoTime}}" bindinput="onTimeInput" />
      <button class="primary-btn visit-submit" loading="{{sending}}" bindtap="submitVideoBooking">提交</button>
    </view>
  </view>

  <view class="record-mask" wx:if="{{recording}}">
    <view class="record-card">
      <view class="record-mic"></view>
      <view class="record-title">正在录音</view>
      <view class="record-text">松开发送，时间太短不会发送</view>
    </view>
  </view>

  <view class="composer-bar">
    <button class="icon-btn" bindtap="toggleVisitPanel">＋</button>
    <button class="mode-btn" bindtap="toggleVoiceMode">{{voiceMode ? '键盘' : '语音'}}</button>
    <button
      wx:if="{{voiceMode}}"
      class="hold-voice {{recording ? 'recording' : ''}}"
      bindtouchstart="startRecord"
      bindtouchend="stopRecord"
      bindtouchcancel="cancelRecord">
      {{recording ? '松开发送' : '按住说话'}}
    </button>
    <input
      wx:else
      class="chat-input"
      confirm-type="send"
      placeholder="输入消息"
      value="{{content}}"
      bindinput="onContentInput"
      bindconfirm="sendText" />
    <button class="send-btn" loading="{{sending}}" disabled="{{!content && !voiceMode}}" bindtap="sendText">发送</button>
  </view>
</view>
