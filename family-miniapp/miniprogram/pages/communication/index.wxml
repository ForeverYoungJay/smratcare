<view class="chat-page">
  <view class="runtime-tip" wx:if="{{runtimeNotice}}">{{runtimeNotice}}</view>

  <view class="chat-header">
    <view>
      <view class="chat-title">在线沟通</view>
      <view class="chat-subtitle">{{activeRoleDesc}}</view>
    </view>
    <view class="role-state">单独会话</view>
  </view>

  <scroll-view class="role-tabs" scroll-x show-scrollbar="{{false}}">
    <block wx:for="{{roleOptions}}" wx:for-item="role" wx:for-index="index" wx:key="value">
      <view
        class="role-tab {{roleIndex === index ? 'active' : ''}}"
        data-index="{{index}}"
        bindtap="selectRole">
        <text class="role-tab-title">{{role.label}}</text>
        <text class="role-tab-desc">{{role.desc}}</text>
      </view>
    </block>
  </scroll-view>

  <view class="error-card" wx:if="{{loadError}}">
    <view class="error-title">沟通暂时不可用</view>
    <view class="error-text">{{loadError}}</view>
    <button class="ghost-btn retry-btn" bindtap="retryLoad">重新加载</button>
  </view>

  <scroll-view
    class="message-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    scroll-into-view="chat-bottom">
    <view wx:if="{{loading}}" class="loading-text">正在同步沟通记录...</view>
    <view wx:if="{{!loading && messages.length === 0}}" class="empty-chat">
      <view class="empty-title">还没有沟通记录</view>
      <view class="empty-text">正在与{{activeRole}}沟通，文字和语音只进入这个会话。</view>
    </view>

    <block wx:for="{{messages}}" wx:for-item="msg" wx:key="id">
      <view class="time-divider" wx:if="{{msg.showTime}}">{{msg.time}}</view>
      <view class="message-row {{msg.mine ? 'mine' : 'theirs'}}">
        <view class="avatar">{{msg.avatarText}}</view>
        <view class="bubble-wrap">
          <view class="sender-name" wx:if="{{!msg.mine}}">{{msg.targetRole}}</view>
          <view class="bubble {{msg.isVoice ? 'voice-bubble' : ''}} {{msg.isVisit ? 'visit-bubble' : ''}}">
            <block wx:if="{{msg.isVoice}}">
              <view
                class="voice-content"
                data-id="{{msg.idText}}"
                data-url="{{msg.playableUrl}}"
                bindtap="playVoice">
                <view class="voice-icon {{playingId === msg.idText ? 'playing' : ''}}"></view>
                <view class="wave">
                  <text></text><text></text><text></text><text></text><text></text>
                </view>
                <view class="voice-duration">{{msg.voiceDurationText || '语音'}}</view>
              </view>
            </block>
            <block wx:elif="{{msg.isVisit}}">
              <view class="visit-title">探视预约</view>
              <view class="visit-text">{{msg.content}}</view>
            </block>
            <block wx:elif="{{msg.isImage}}">
              <image
                class="chat-image"
                src="{{msg.playableUrl}}"
                mode="aspectFill"
                data-url="{{msg.playableUrl}}"
                bindtap="previewImage" />
            </block>
            <block wx:elif="{{msg.isMediaVideo}}">
              <video
                class="chat-video"
                src="{{msg.playableUrl}}"
                controls
                show-center-play-btn
                object-fit="cover"></video>
            </block>
            <block wx:else>
              <view class="message-text">{{msg.content}}</view>
            </block>
          </view>
          <view class="message-status">{{msg.status}} · {{msg.msgTypeText}}</view>
        </view>
      </view>
    </block>
    <view id="chat-bottom" class="chat-bottom"></view>
  </scroll-view>

  <view class="visit-panel" wx:if="{{showVisitPanel}}">
    <button class="visit-close panel-close" bindtap="toggleVisitPanel">×</button>
    <view class="tool-grid">
      <button class="tool-item" bindtap="chooseImage">
        <text class="tool-icon">图</text>
        <text class="tool-label">照片</text>
      </button>
      <button class="tool-item" bindtap="chooseVideo">
        <text class="tool-icon">视</text>
        <text class="tool-label">视频</text>
      </button>
      <button class="tool-item visit-tool {{bookingOpen ? 'active' : ''}}" bindtap="openBookingPanel">
        <text class="tool-icon">访</text>
        <text class="tool-label">探视</text>
      </button>
    </view>
    <view class="visit-booking" wx:if="{{bookingOpen}}">
      <view class="visit-panel-head">
        <view>
          <view class="visit-panel-title">预约探视时间</view>
          <view class="visit-panel-subtitle">提交后会进入生活管家会话</view>
        </view>
      </view>
      <view class="visit-panel-row">
        <input class="visit-input" value="{{videoTime}}" bindinput="onTimeInput" />
        <button class="primary-btn visit-submit" loading="{{sending}}" bindtap="submitVideoBooking">提交</button>
      </view>
    </view>
  </view>

  <view class="record-mask" wx:if="{{recording}}">
    <view class="record-card">
      <view class="record-mic"></view>
      <view class="record-title">正在录音</view>
      <view class="record-text">松开发送，时间太短不会发送</view>
    </view>
  </view>

  <view class="composer-bar">
    <button class="icon-btn add-btn" aria-label="更多" bindtap="toggleVisitPanel">+</button>
    <button
      wx:if="{{voiceMode}}"
      class="hold-voice {{recording ? 'recording' : ''}}"
      bindtouchstart="startRecord"
      bindtouchend="stopRecord"
      bindtouchcancel="cancelRecord">
      {{recording ? '松开发送' : '按住说话'}}
    </button>
    <input
      wx:else
      class="chat-input"
      confirm-type="send"
      placeholder="输入消息"
      value="{{content}}"
      bindinput="onContentInput"
      bindconfirm="sendText" />
    <button
      wx:if="{{voiceMode || !canSend}}"
      class="icon-btn voice-toggle"
      aria-label="{{voiceMode ? '切换键盘' : '切换语音'}}"
      bindtap="toggleVoiceMode">
      <view wx:if="{{voiceMode}}" class="keyboard-glyph">
        <text></text><text></text><text></text><text></text><text></text><text></text>
      </view>
      <view wx:else class="mic-glyph"></view>
    </button>
    <button wx:else class="send-btn" loading="{{sending}}" disabled="{{sending}}" bindtap="sendText">发送</button>
  </view>
</view>
