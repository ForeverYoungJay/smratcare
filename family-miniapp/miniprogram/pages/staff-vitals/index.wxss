.form-card {
  margin-top: 22rpx;
  padding: 26rpx;
}

.field {
  margin-top: 22rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #60716b;
  font-size: 23rpx;
  font-weight: 850;
}

.picker-line,
.input-line,
.textarea-line {
  width: 100%;
  border-radius: 14rpx;
  border: 1rpx solid #d9e3df;
  background: #ffffff;
  color: #182420;
  font-size: 25rpx;
}

.picker-line,
.input-line {
  min-height: 74rpx;
  line-height: 74rpx;
  padding: 0 18rpx;
}

.textarea-line {
  min-height: 130rpx;
  padding: 18rpx;
  line-height: 1.55;
}

.value-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.value-input {
  flex: 1;
}

.unit-label {
  min-width: 96rpx;
  color: #246b5f;
  font-size: 24rpx;
  font-weight: 900;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.abnormal-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f6faf8;
  border: 1rpx solid #dcebe5;
}

.abnormal-title {
  color: #182430;
  font-size: 26rpx;
  font-weight: 900;
}

.abnormal-sub {
  margin-top: 6rpx;
  color: #73808c;
  font-size: 22rpx;
  line-height: 1.45;
}

.status-pill {
  flex: none;
  height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 46rpx;
}

.status-pill.done {
  background: #e5f5ef;
  color: #16704f;
}

.status-pill.danger {
  background: #fde8e5;
  color: #b42318;
}

.submit-btn {
  width: 100%;
  margin-top: 24rpx;
}

.search-row {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  border: 1rpx solid #d9e3df;
  background: #ffffff;
  color: #182420;
  font-size: 24rpx;
}

.search-btn {
  width: 140rpx;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  margin: 18rpx 0 0;
  padding-bottom: 4rpx;
}

.filter {
  flex: 0 0 auto;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #edf2f0;
  color: #62716b;
  font-size: 24rpx;
  font-weight: 850;
}

.filter.active {
  background: #246b5f;
  color: #ffffff;
}

.retry-btn {
  margin-top: 20rpx;
}

.empty-card {
  margin-top: 18rpx;
  padding: 34rpx;
}

.vital-card {
  margin-top: 18rpx;
  padding: 26rpx;
}

.vital-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.vital-title {
  color: #182430;
  font-size: 29rpx;
  font-weight: 900;
}

.vital-meta {
  margin-top: 8rpx;
  color: #73808c;
  font-size: 22rpx;
}

.vital-value {
  margin-top: 18rpx;
  color: #246b5f;
  font-size: 44rpx;
  font-weight: 950;
}

.vital-value text {
  color: #73808c;
  font-size: 22rpx;
  font-weight: 850;
}

.vital-remark {
  margin-top: 14rpx;
  color: #465563;
  font-size: 24rpx;
  line-height: 1.55;
}
