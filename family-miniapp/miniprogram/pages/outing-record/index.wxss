.card { padding: 24rpx; }
.item { margin-top: 14rpx; padding: 14rpx; border: 1rpx solid #edf2ef; border-radius: 12rpx; background: #f7faf8; }
.line { margin-top: 8rpx; display: flex; justify-content: space-between; gap: 20rpx; }
.label { width: 140rpx; font-size: 22rpx; color: #71807a; }
.value { flex: 1; font-size: 23rpx; color: #182420; text-align: right; }
.status { font-size: 23rpx; color: #16704f; }
