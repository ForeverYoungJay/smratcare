.page-head { padding: 6rpx 8rpx 20rpx; }
.head-row { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.loading-tip { padding: 40rpx; text-align: center; color: var(--faint); font-size: 26rpx; }

.apply-btn {
  flex: none;
  height: 66rpx;
  line-height: 66rpx;
  margin: 0;
  padding: 0 30rpx;
  border-radius: 999rpx;
  background: var(--brand);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 700;
}
.apply-btn::after { border: 0; }

.form-card { padding: 24rpx; margin-bottom: 18rpx; }
.form-title { font-size: 29rpx; font-weight: 800; color: var(--ink); margin-bottom: 8rpx; }
.field { margin-top: 18rpx; }
.field-label { display: block; font-size: 24rpx; color: var(--muted); margin-bottom: 10rpx; }
.input, .picker {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 22rpx;
  border-radius: var(--radius-ctl);
  background: #ffffff;
  border: 1rpx solid #D7DED8;
  font-size: 27rpx;
  color: var(--ink);
}
.picker { color: var(--ink); }
.picker-row { display: flex; gap: 16rpx; }
.picker-row .picker { flex: 1; }
.form-card .primary-btn { margin-top: 24rpx; }

.outing-card { padding: 24rpx; margin-bottom: 16rpx; }
.outing-top { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.outing-title { font-size: 28rpx; font-weight: 800; color: var(--ink); flex: 1; min-width: 0; }
.outing-line { margin-top: 12rpx; display: flex; gap: 18rpx; }
.outing-line .k { flex: none; width: 128rpx; font-size: 24rpx; color: var(--muted); }
.outing-line .v { flex: 1; font-size: 25rpx; color: var(--ink); line-height: 1.6; }
.outing-foot { margin-top: 18rpx; padding-top: 16rpx; border-top: 1rpx solid var(--border); display: flex; justify-content: flex-end; }

.cancel-btn {
  height: 60rpx;
  line-height: 60rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--danger);
  border: 1rpx solid rgba(201, 80, 75, 0.4);
  font-size: 24rpx;
  font-weight: 700;
}
.cancel-btn::after { border: 0; }
