.card {
  padding: 28rpx;
}

.runtime-hint {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #f5f8f6;
  color: #5d6c66;
  font-size: 22rpx;
  line-height: 1.55;
}

.guard-brief {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #edf6f2;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.guard-main {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.guard-title {
  font-size: 26rpx;
  color: #1f5f55;
  font-weight: 900;
}

.guard-sub {
  font-size: 22rpx;
  color: #5d6c66;
}

.mini-guard-btn {
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  padding: 0 18rpx;
}

.line {
  min-height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 1rpx solid #edf2ef;
  color: #34443f;
  font-size: 24rpx;
}

.line text:first-child {
  color: #71807a;
}

.line text:last-child {
  font-weight: 800;
  color: #182420;
}

.line:last-child {
  border-bottom: none;
}

.warn {
  color: #9a5b05 !important;
}

.switch-line {
  align-items: center;
}

.detail-title {
  margin-top: 4rpx;
  margin-bottom: 8rpx;
}

.amount-input {
  width: 220rpx;
  height: 56rpx;
  padding: 0 14rpx;
  border: 1rpx solid #d9e3df;
  border-radius: 12rpx;
  background: #ffffff;
  text-align: right;
  font-size: 25rpx;
}

.preset-row {
  margin-top: 16rpx;
}

.preset-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 22rpx;
  color: #71807a;
}

.preset-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.preset-chip,
.filter-chip {
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d9e3df;
  background: #ffffff;
  color: #52615c;
  font-size: 23rpx;
}

.preset-chip-active,
.filter-chip-active {
  background: #246b5f;
  border-color: #246b5f;
  color: #ffffff;
  font-weight: 900;
}

.preview-line {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #eef6ff;
  color: #255a91;
  font-size: 23rpx;
  font-weight: 800;
}

.tip-text {
  margin-top: 10rpx;
  color: #71807a;
  font-size: 22rpx;
  line-height: 1.55;
}

.warn-box {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #fff7e8;
  border: 1rpx solid #f3d29b;
}

.warn-title {
  font-size: 25rpx;
  font-weight: 900;
  color: #8a5508;
}

.warn-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8a5508;
}

.warn-action {
  margin-top: 12rpx;
}

.filter-scroll {
  margin-top: 12rpx;
  width: 100%;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 10rpx;
}

.order-item {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f7faf8;
  border: 1rpx solid #edf2ef;
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.order-side {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.order-no {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: #34443f;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-status {
  font-size: 22rpx;
  color: #16704f;
  font-weight: 900;
}

.order-arrow {
  color: #93a19c;
  font-size: 20rpx;
}

.order-sub {
  margin-top: 7rpx;
  font-size: 22rpx;
  color: #71807a;
  line-height: 1.45;
}
