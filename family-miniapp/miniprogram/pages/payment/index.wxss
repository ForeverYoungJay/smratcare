.card {
  padding: 28rpx;
}

.runtime-hint {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #f5f8f6;
  color: #5d6c66;
  font-size: 22rpx;
  line-height: 1.55;
}

.guard-brief {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #E8F3EF;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.guard-main {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.guard-title {
  font-size: 26rpx;
  color: #185C4E;
  font-weight: 900;
}

.guard-sub {
  font-size: 22rpx;
  color: #5d6c66;
}

.mini-guard-btn {
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  padding: 0 18rpx;
}

.line {
  min-height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 1rpx solid #E4E7E0;
  color: #34443f;
  font-size: 24rpx;
}

.line text:first-child {
  color: #5C6F69;
}

.line text:last-child {
  font-weight: 800;
  color: #22332E;
}

.line:last-child {
  border-bottom: none;
}

.warn {
  color: #B27221 !important;
}

.switch-line {
  align-items: center;
}

.detail-title {
  margin-top: 4rpx;
  margin-bottom: 8rpx;
}

.amount-input {
  width: 220rpx;
  height: 56rpx;
  padding: 0 14rpx;
  border: 1rpx solid #D7DED8;
  border-radius: 12rpx;
  background: #ffffff;
  text-align: right;
  font-size: 25rpx;
}

.preset-row {
  margin-top: 16rpx;
}

.preset-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 22rpx;
  color: #5C6F69;
}

.preset-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.preset-chip,
.filter-chip {
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid #D7DED8;
  background: #ffffff;
  color: #52615c;
  font-size: 23rpx;
}

.preset-chip-active,
.filter-chip-active {
  background: #21705F;
  border-color: #21705F;
  color: #ffffff;
  font-weight: 900;
}

.preview-line {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #eef6ff;
  color: #3D7FA6;
  font-size: 23rpx;
  font-weight: 800;
}

.tip-text {
  margin-top: 10rpx;
  color: #5C6F69;
  font-size: 22rpx;
  line-height: 1.55;
}

.warn-box {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #fff7e8;
  border: 1rpx solid #f3d29b;
}

.warn-box.subtle {
  margin-top: 16rpx;
}

.warn-title {
  font-size: 25rpx;
  font-weight: 900;
  color: #8a5508;
}

.warn-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8a5508;
}

.warn-action {
  margin-top: 12rpx;
}

.filter-scroll {
  margin-top: 12rpx;
  width: 100%;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 10rpx;
}

.order-item {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #FAFAF7;
  border: 1rpx solid #E4E7E0;
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.order-side {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.order-no {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: #34443f;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-status {
  font-size: 22rpx;
  color: #21705F;
  font-weight: 900;
}

.order-arrow {
  color: #93a19c;
  font-size: 20rpx;
}

.order-sub {
  margin-top: 7rpx;
  font-size: 22rpx;
  color: #5C6F69;
  line-height: 1.45;
}

/* 待支付订单自动刷新提示 */
.sync-hint {
  margin-top: 14rpx;
  padding: 14rpx 20rpx;
  border-radius: 14rpx;
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 24rpx;
  line-height: 1.5;
}

.sync-dot {
  color: var(--accent);
  animation: syncBlink 1.1s ease-in-out infinite;
}

@keyframes syncBlink {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

.bill-items-toggle { padding: 16rpx 0; color: #21705F; font-size: 26rpx; }
.bill-item-line { padding-left: 16rpx; }
.bill-item-main { display: flex; flex-direction: column; }
.bill-item-remark { font-size: 22rpx; color: #8a9a93; word-break: break-all; }
.bill-items-empty { padding: 16rpx 0; font-size: 24rpx; color: #8a9a93; }
.invoice-row { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; }
.invoice-tip { font-size: 24rpx; color: #5C6F69; }
.invoice-btn { border: 2rpx solid #21705F; color: #21705F; border-radius: 999rpx; background: transparent; }
