.card { padding: 24rpx; }
.item { display: flex; justify-content: space-between; align-items: center; padding: 18rpx 0; border-bottom: 1rpx solid #E4E7E0; font-size: 26rpx; color: #22332E; }
.item:last-child { border-bottom: none; }
.subscribe-item { align-items: flex-start; gap: 14rpx; }
.subscribe-main { display: flex; flex-direction: column; gap: 6rpx; }
.subscribe-status { font-size: 22rpx; color: #5C6F69; }
.subscribe-btn { height: 56rpx; line-height: 56rpx; font-size: 22rpx; padding: 0 18rpx; }
.template-list { margin-top: 10rpx; display: flex; flex-wrap: wrap; gap: 8rpx; }
.template-item { padding: 6rpx 10rpx; border-radius: 999rpx; background: #E8F3EF; color: #21705F; font-size: 20rpx; }
.list-empty { padding: 30rpx 0; text-align: center; font-size: 23rpx; color: #7C8984; }
.error-box { padding: 30rpx 0; text-align: center; }
.error-text { font-size: 23rpx; color: #B4553B; line-height: 1.6; }
.retry-btn { margin-top: 14rpx; display: inline-block; height: 60rpx; line-height: 60rpx; font-size: 23rpx; padding: 0 30rpx; }
.action { margin-top: 18rpx; width: 100%; }
