.panel {
  margin-bottom: 18rpx;
  padding: 24rpx;
}

.checked {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #71807a;
}

.summary-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10rpx;
}

.summary-item {
  padding: 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d8e5e8;
  background: #f8fbfc;
}

.summary-item .label {
  display: block;
  font-size: 22rpx;
  color: #71807a;
}

.summary-item .value {
  display: block;
  margin-top: 6rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #182420;
}

.ops-row {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
}

.op {
  flex: 1;
}

.item {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  border: 1rpx solid #e2e8f0;
  background: #fbfdff;
}

.item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title {
  font-size: 27rpx;
  color: #182420;
  font-weight: 700;
}

.badge {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
}

.badge-ok {
  color: #16704f;
  background: #e8f7ef;
}

.badge-warn {
  color: #9a5b05;
  background: #fff7e8;
}

.badge-neutral {
  color: #475569;
  background: #f1f5f9;
}

.badge-danger {
  color: #b42318;
  background: #fff4f2;
}

.hint {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #475569;
  line-height: 1.6;
}

.action {
  margin-top: 10rpx;
  color: #1b5f69;
  font-size: 22rpx;
}
