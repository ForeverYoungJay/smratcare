.login-page {
  min-height: 100vh;
  padding-top: 64rpx;
}

.brand {
  padding: 36rpx;
  margin-bottom: 28rpx;
  background: linear-gradient(145deg, #ffffff, #f0f8f9);
}

.brand-title {
  font-size: 46rpx;
  font-weight: 700;
  color: #194f5e;
}

.brand-subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
}

.mode-row {
  margin-top: 22rpx;
  display: inline-flex;
  background: #eef4f7;
  border-radius: 999rpx;
  padding: 6rpx;
}

.mode {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #6b7280;
  border-radius: 999rpx;
}

.mode.active {
  background: #194f5e;
  color: #fff;
}

.form {
  padding: 30rpx;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.input {
  background: #f8fafc;
  border: 1rpx solid #dbe3ea;
  border-radius: 14rpx;
  padding: 20rpx;
  font-size: 30rpx;
}

.code-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-end;
}

.code-main {
  flex: 1;
}

.code-btn {
  width: 220rpx;
  height: 82rpx;
  line-height: 82rpx;
  font-size: 26rpx;
}

.login-btn {
  margin-top: 18rpx;
}

.tips {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 22rpx;
}
