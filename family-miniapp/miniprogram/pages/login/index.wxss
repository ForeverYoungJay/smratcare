.login-page {
  min-height: 100vh;
  padding-top: 54rpx;
}

.brand {
  padding: 36rpx;
  margin-bottom: 22rpx;
  background:
    linear-gradient(135deg, rgba(36, 107, 95, 0.13), rgba(255, 255, 255, 0) 54%),
    #ffffff;
}

.brand-title {
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 900;
  color: #16231f;
}

.brand-subtitle {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #52615c;
  line-height: 1.55;
}

.runtime-warning,
.runtime-tip {
  margin-top: 18rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
}

.runtime-warning {
  background: #fff4f2;
  color: #b42318;
  border: 1rpx solid #f0c2bd;
}

.org-line {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #71807a;
}

.org-loading {
  margin-left: 10rpx;
  color: #246b5f;
}

.mode-row {
  margin-top: 24rpx;
  display: flex;
  background: #edf2ef;
  border-radius: 999rpx;
  padding: 6rpx;
}

.mode {
  flex: 1;
  text-align: center;
  padding: 11rpx 8rpx;
  font-size: 23rpx;
  color: #71807a;
  border-radius: 999rpx;
}

.mode.active {
  background: #246b5f;
  color: #ffffff;
  font-weight: 900;
}

.form {
  padding: 30rpx;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 23rpx;
  color: #71807a;
  font-weight: 700;
}

.input {
  height: 78rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #f7faf8;
  border: 1rpx solid #d9e3df;
  font-size: 28rpx;
}

.code-row {
  display: flex;
  gap: 14rpx;
  align-items: flex-end;
}

.code-main {
  flex: 1;
}

.code-btn {
  width: 210rpx;
  height: 78rpx;
  line-height: 78rpx;
  font-size: 24rpx;
}

.login-btn {
  margin-top: 8rpx;
  width: 100%;
}

.tips {
  margin-top: 14rpx;
  color: #71807a;
  font-size: 22rpx;
  line-height: 1.55;
}

.agreement-box {
  margin-top: 24rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #f7faf8;
}

.agreement-title {
  font-size: 24rpx;
  font-weight: 900;
  color: #182420;
}

.agreement-text {
  margin-top: 8rpx;
  font-size: 21rpx;
  line-height: 1.6;
  color: #71807a;
}
