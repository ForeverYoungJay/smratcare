/* ===== 登录页 · 品牌感 · 温暖大按钮 ===== */

.login-page {
  min-height: 100vh;
  padding-top: 54rpx;
}

/* ---- 品牌卡（品牌渐变） ---- */
.brand {
  padding: 44rpx 36rpx 36rpx;
  margin-bottom: 24rpx;
  border: none;
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, #21705F, #2E8A72);
  box-shadow: 0 10rpx 28rpx rgba(33, 112, 95, 0.28);
}

.brand-title {
  font-size: 56rpx;
  line-height: 1.18;
  font-weight: 900;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.brand-subtitle {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.55;
}

.brand .runtime-warning,
.brand .runtime-tip {
  margin: 18rpx 0 0;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  font-size: 23rpx;
  line-height: 1.6;
}

.brand .runtime-warning {
  background: rgba(255, 255, 255, 0.94);
  color: var(--danger);
  border: none;
}

.brand .runtime-tip {
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.92);
  border: none;
}

.org-line {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.78);
}

.org-loading {
  margin-left: 10rpx;
  color: rgba(255, 255, 255, 0.92);
}

/* ---- 身份 / 模式切换 ---- */
.identity-row {
  margin-top: 26rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.identity {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.85);
  font-size: 28rpx;
  font-weight: 800;
  text-align: center;
}

.identity.active {
  background: #ffffff;
  color: var(--brand-deep);
  font-weight: 900;
  box-shadow: 0 6rpx 16rpx rgba(24, 92, 78, 0.25);
}

.mode-row {
  margin-top: 18rpx;
  display: flex;
  background: rgba(255, 255, 255, 0.16);
  border-radius: 999rpx;
  padding: 6rpx;
}

.mode {
  flex: 1;
  text-align: center;
  padding: 14rpx 8rpx;
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.85);
  border-radius: 999rpx;
}

.mode.active {
  background: #ffffff;
  color: var(--brand-deep);
  font-weight: 900;
}

/* ---- 表单 ---- */
.form {
  padding: 34rpx 30rpx;
  border-radius: var(--radius-lg);
}

.field {
  margin-bottom: 26rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: var(--muted);
  font-weight: 700;
}

.input {
  height: 88rpx;
  padding: 0 22rpx;
  border-radius: var(--radius-ctl);
  background: #FAFBF9;
  border: 1rpx solid #D7DED8;
  font-size: 30rpx;
  color: var(--ink);
}

.code-row {
  display: flex;
  gap: 14rpx;
  align-items: flex-end;
}

.code-main {
  flex: 1;
}

.code-btn {
  width: 220rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 25rpx;
}

.login-btn {
  margin-top: 12rpx;
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 32rpx;
  border-radius: 16rpx;
}

.tips {
  margin-top: 16rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.6;
}

.agreement-box {
  margin-top: 26rpx;
  padding: 20rpx 22rpx;
  border-radius: 16rpx;
  background: var(--brand-soft);
}

.agreement-title {
  font-size: 25rpx;
  font-weight: 800;
  color: var(--brand-deep);
}

.agreement-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--muted);
}

/* 微信一键登录 */
.wechat-login {
  margin-top: 26rpx;
}

.wechat-divider {
  display: flex;
  align-items: center;
  margin: 6rpx 0 22rpx;
  color: var(--faint);
  font-size: 24rpx;
}

.wechat-divider::before,
.wechat-divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: var(--border);
}

.wechat-divider text {
  padding: 0 20rpx;
}

.wechat-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  background: #07C160;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  border: 0;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.22);
}

.wechat-btn[disabled] {
  opacity: 0.55;
  box-shadow: none;
}

.wechat-icon {
  margin-right: 12rpx;
  font-size: 34rpx;
}

.wechat-tip {
  margin-top: 14rpx;
  text-align: center;
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.6;
}
