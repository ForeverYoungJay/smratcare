.login-page {
  min-height: 100vh;
  padding-top: 56rpx;
}

.brand {
  padding: 42rpx 36rpx 32rpx;
  margin-bottom: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(240, 199, 135, 0.24) 0%, rgba(240, 199, 135, 0) 34%),
    linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(238, 247, 248, 0.94));
}

.brand-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #194f5e;
  letter-spacing: 1rpx;
}

.brand-subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #526274;
  line-height: 1.7;
}

.runtime-warning,
.runtime-tip {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  line-height: 1.6;
}

.runtime-warning {
  background: #fff1f2;
  color: #b91c1c;
  border: 1rpx solid #fecdd3;
}

.runtime-tip {
  background: #eef6ff;
  color: #1d4ed8;
  border: 1rpx solid #bfdbfe;
}

.org-line {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.runtime-meta {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  font-size: 20rpx;
  color: #64748b;
  word-break: break-all;
}

.org-loading {
  margin-left: 10rpx;
  color: #2c7a84;
}

.mode-row {
  margin-top: 28rpx;
  display: flex;
  background: rgba(232, 241, 244, 0.9);
  border-radius: 999rpx;
  padding: 6rpx;
}

.mode {
  flex: 1;
  text-align: center;
  padding: 14rpx 10rpx;
  font-size: 24rpx;
  color: #6b7280;
  border-radius: 999rpx;
}

.mode.active {
  background: linear-gradient(120deg, #194f5e, #2c7a84);
  color: #fff;
  box-shadow: 0 10rpx 20rpx rgba(25, 79, 94, 0.18);
}

.form {
  padding: 34rpx 28rpx 30rpx;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.input {
  background: rgba(248, 250, 252, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.24);
  border-radius: 18rpx;
  padding: 22rpx 20rpx;
  font-size: 30rpx;
  color: #18212b;
  box-sizing: border-box;
}

.code-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-end;
}

.code-main {
  flex: 1;
}

.code-btn {
  width: 230rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}

.login-btn {
  margin-top: 22rpx;
}

.tips {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.7;
}

.agreement-box {
  margin-top: 28rpx;
  padding: 22rpx 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(248, 250, 252, 0.98), rgba(241, 245, 249, 0.9));
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.agreement-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2937;
}

.agreement-text {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #64748b;
}

@media screen and (max-width: 360px) {
  .brand {
    padding: 36rpx 28rpx 28rpx;
  }

  .brand-title {
    font-size: 46rpx;
  }

  .form {
    padding: 28rpx 22rpx 24rpx;
  }

  .code-row {
    flex-direction: column;
    align-items: stretch;
  }

  .code-btn {
    width: 100%;
  }
}
