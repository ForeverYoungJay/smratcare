.card { padding: 24rpx; }
.item { margin-top: 14rpx; background: #f8fafc; border-radius: 14rpx; border: 1rpx solid #e5edf2; padding: 16rpx; }
.row-top { display: flex; justify-content: space-between; align-items: center; }
.name { font-size: 28rpx; color: #111827; font-weight: 700; }
.price { font-size: 26rpx; color: #b45309; font-weight: 700; }
.meta { margin-top: 6rpx; font-size: 22rpx; color: #6b7280; }
.desc { margin-top: 6rpx; font-size: 23rpx; color: #4b5563; }
.action { margin-top: 12rpx; height: 62rpx; line-height: 62rpx; font-size: 24rpx; }
