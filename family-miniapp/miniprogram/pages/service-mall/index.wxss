.card {
  padding: 28rpx;
}

.order-card {
  margin-top: 20rpx;
}

.bind-alert {
  margin-top: 18rpx;
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #fff7e8;
  border: 1rpx solid #f3d29b;
}

.bind-title {
  font-size: 26rpx;
  color: #8a5508;
  font-weight: 900;
}

.bind-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a5508;
}

.bind-btn {
  margin-top: 14rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
}

.ghost-retry {
  background: #fffdf7;
}

.field-label {
  margin-bottom: 8rpx;
  font-size: 23rpx;
  color: #5C6F69;
}

.elder-row,
.category-row {
  margin-top: 18rpx;
}

.elder-picker,
.category-picker,
.search-input {
  min-height: 72rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #FAFAF7;
  border: 1rpx solid #D7DED8;
  color: #22332E;
  font-size: 25rpx;
  display: flex;
  align-items: center;
}

.search-row {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.search-input {
  flex: 1;
}

.search-btn {
  width: 128rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 24rpx;
}

.retry-btn {
  margin-top: 16rpx;
  font-size: 22rpx;
}

.item {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #E4E7E0;
}

.product-main {
  display: flex;
  gap: 16rpx;
}

.product-image {
  width: 156rpx;
  height: 156rpx;
  flex: 0 0 156rpx;
  border-radius: 14rpx;
  background: #dfe8e3;
}

.product-image.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  color: #21705F;
  background: #E8F3EF;
  font-size: 22rpx;
  line-height: 1.35;
  text-align: center;
}

.product-info {
  flex: 1;
  min-width: 0;
}

.row-top {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.name {
  font-size: 29rpx;
  line-height: 1.3;
  color: #22332E;
  font-weight: 900;
}

.price {
  font-size: 27rpx;
  color: #B27221;
  font-weight: 900;
}

.meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #5C6F69;
}

.stock {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.stock-OUT { color: #C9504B; }
.stock-LOW { color: #B27221; }
.stock-OK { color: #21705F; }

.qty-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.qty-label {
  font-size: 24rpx;
  color: #52615c;
}

.qty-btn {
  width: 52rpx;
  min-width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: #E4E7E0;
  color: #22332E;
  font-size: 28rpx;
}

.qty-input {
  width: 108rpx;
  height: 52rpx;
  border-radius: 999rpx;
  border: 1rpx solid #D7DED8;
  background: #ffffff;
  text-align: center;
  font-size: 24rpx;
}

.action-row {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.action-btn {
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
}

.tab-row {
  display: flex;
  gap: 10rpx;
  margin-top: 18rpx;
  margin-bottom: 10rpx;
}

.tab {
  flex: 1;
  padding: 10rpx 0;
  border-radius: 999rpx;
  background: #f1f5f3;
  color: #52615c;
  text-align: center;
  font-size: 23rpx;
}

.tab-active {
  color: #ffffff;
  background: #21705F;
  font-weight: 900;
}

.order-item {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #FAFAF7;
  border: 1rpx solid #E4E7E0;
}

.order-head,
.order-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
}

.order-no {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: #22332E;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-status,
.order-more {
  font-size: 22rpx;
  color: #21705F;
  font-weight: 800;
}

.order-line,
.order-foot {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #5d6c66;
}

.order-more {
  margin-top: 8rpx;
  text-align: right;
}
