.hero {
  padding: 32rpx 28rpx;
  margin-bottom: 18rpx;
  background: var(--brand-gradient);
  border: 0;
}
.hero-date { color: #ffffff; font-size: 40rpx; font-weight: 800; }
.hero-hospital { margin-top: 12rpx; color: rgba(255, 255, 255, 0.9); font-size: 27rpx; }

.detail-block { padding: 24rpx; margin-bottom: 18rpx; }
.block-title { font-size: 25rpx; font-weight: 800; color: var(--muted); }
.diagnosis-title { color: var(--brand); }
.block-text { margin-top: 14rpx; font-size: 28rpx; line-height: 1.7; color: var(--ink); }
.block-text.strong { font-weight: 700; }

.detail-tip {
  margin: 8rpx 8rpx 40rpx;
  padding: 18rpx 20rpx;
  border-radius: var(--radius-ctl);
  background: var(--brand-soft);
  color: var(--muted);
  font-size: 23rpx;
  line-height: 1.6;
}
