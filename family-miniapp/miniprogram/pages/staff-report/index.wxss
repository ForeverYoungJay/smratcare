.summary-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.summary-card {
  padding: 20rpx 12rpx;
  text-align: center;
}

.summary-card text,
.summary-card strong {
  display: block;
}

.summary-card text {
  color: #73808c;
  font-size: 22rpx;
  font-weight: 800;
}

.summary-card strong {
  margin-top: 8rpx;
  color: #21705F;
  font-size: 38rpx;
  font-weight: 900;
}

.summary-card.success strong {
  color: #21705F;
}

.summary-card.warning strong {
  color: #9a6400;
}

.form-card {
  margin-top: 18rpx;
  padding: 26rpx;
}

.field {
  margin-top: 22rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #60716b;
  font-size: 23rpx;
  font-weight: 850;
}

.picker-line,
.input-line,
.textarea-line {
  width: 100%;
  border-radius: 14rpx;
  border: 1rpx solid #D7DED8;
  background: #ffffff;
  color: #22332E;
  font-size: 25rpx;
}

.picker-line,
.input-line {
  min-height: 74rpx;
  line-height: 74rpx;
  padding: 0 18rpx;
}

.textarea-line {
  min-height: 150rpx;
  padding: 18rpx;
  line-height: 1.55;
}

.textarea-line.small {
  min-height: 120rpx;
}

.button-row {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.half-btn {
  flex: 1;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  margin: 22rpx 0 0;
  padding-bottom: 4rpx;
}

.filter {
  flex: 0 0 auto;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #edf2f0;
  color: #62716b;
  font-size: 24rpx;
  font-weight: 850;
}

.filter.active {
  background: #21705F;
  color: #ffffff;
}

.retry-btn {
  margin-top: 20rpx;
}

.empty-card {
  margin-top: 18rpx;
  padding: 34rpx;
}

.report-card {
  margin-top: 18rpx;
  padding: 26rpx;
}

.report-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.report-title {
  color: #22332E;
  font-size: 30rpx;
  font-weight: 900;
}

.report-meta {
  margin-top: 8rpx;
  color: #73808c;
  font-size: 22rpx;
}

.status-pill {
  flex: none;
  height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #FBF0E2;
  color: #B27221;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 46rpx;
}

.status-pill.done {
  background: #E8F3EF;
  color: #21705F;
}

.report-line {
  margin-top: 14rpx;
  color: #465563;
  font-size: 24rpx;
  line-height: 1.55;
}

.report-line.muted {
  color: #73808c;
}

.submit-draft {
  width: 100%;
  margin-top: 20rpx;
}
