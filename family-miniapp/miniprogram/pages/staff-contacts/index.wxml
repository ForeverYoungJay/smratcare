<view class="container">
  <view class="section-title">员工通讯录</view>
  <view class="section-subtitle">快速搜索护理、医生、后勤和管理人员，一键拨号协同</view>

  <view class="search-row">
    <input class="search-input" value="{{keyword}}" placeholder="搜索姓名、账号、工号、手机号" bindinput="onKeywordInput" confirm-type="search" bindconfirm="searchContacts" />
    <button class="ghost-btn search-btn" bindtap="searchContacts">搜索</button>
  </view>

  <view class="surface state-card" wx:if="{{loading}}">
    <view class="state-title">正在加载通讯录</view>
  </view>

  <view class="surface state-card" wx:if="{{!loading && loadError}}">
    <view class="state-title">通讯录加载失败</view>
    <view class="section-subtitle">{{loadError}}</view>
    <button class="ghost-btn retry-btn" bindtap="loadData">重新加载</button>
  </view>

  <view class="surface empty-card" wx:if="{{!loading && !loadError && contacts.length === 0}}">
    <view class="state-title">暂无联系人</view>
    <view class="section-subtitle">换个姓名、工号或手机号再试试。</view>
  </view>

  <view wx:if="{{!loading && !loadError && contacts.length}}">
    <block wx:for="{{contacts}}" wx:key="id">
      <view class="surface contact-card">
        <view class="avatar">{{item.avatarText}}</view>
        <view class="contact-main">
          <view class="contact-name">{{item.name}}</view>
          <view class="contact-meta">{{item.roleText}} · {{item.departmentText}}</view>
          <view class="contact-meta">工号 {{item.staffNo || '-'}} · {{item.phoneText}}</view>
        </view>
        <button class="primary-btn call-btn" data-phone="{{item.phone}}" bindtap="call">拨号</button>
      </view>
    </block>
  </view>
</view>
