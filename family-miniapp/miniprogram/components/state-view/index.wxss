/* 通用状态组件样式，全部引用全局设计变量，保证与整体视觉一致。 */
.sv-skeleton {
  padding: 24rpx 28rpx;
  margin-bottom: 18rpx;
}

.sv-sk-row {
  padding: 18rpx 0;
}

.sv-sk-row + .sv-sk-row {
  border-top: 1rpx solid var(--border);
}

.sv-sk-line {
  height: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ECEFEA 25%, #F5F7F3 37%, #ECEFEA 63%);
  background-size: 400% 100%;
  animation: sv-shimmer 1.3s ease infinite;
}

.sv-sk-line--lg {
  width: 62%;
}

.sv-sk-line--sm {
  width: 38%;
  margin-top: 14rpx;
  height: 20rpx;
}

@keyframes sv-shimmer {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}

.sv-state {
  padding: 56rpx 40rpx;
  margin-bottom: 18rpx;
  text-align: center;
}

.sv-icon {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  font-size: 48rpx;
  line-height: 96rpx;
  font-weight: 700;
}

.sv-icon--empty {
  background: var(--brand-soft);
  color: var(--brand);
}

.sv-icon--error {
  background: #F9E7E6;
  color: var(--danger);
}

.sv-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--ink);
}

.sv-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: var(--muted);
}

.sv-retry {
  margin: 24rpx auto 0;
  display: inline-flex;
  align-items: center;
  min-width: 220rpx;
}
