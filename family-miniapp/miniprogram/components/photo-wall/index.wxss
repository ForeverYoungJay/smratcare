.photo-wall {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.pw-item {
  position: relative;
  width: 100%;
}

.pw-img {
  width: 100%;
  height: 132rpx;
  border-radius: 14rpx;
  background: #eef2f5;
}

.pw-del {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(34, 51, 46, 0.78);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

.pw-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 132rpx;
  border-radius: 14rpx;
  border: 2rpx dashed #b9cbc3;
  background: #f6faf8;
  color: #60716b;
}

.pw-add-hover {
  background: #E8F3EF;
}

.pw-add-icon {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
  color: #21705F;
}

.pw-add-text {
  font-size: 21rpx;
  font-weight: 800;
}
