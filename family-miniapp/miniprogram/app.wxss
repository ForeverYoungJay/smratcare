page {
  /* ===== 设计变量（温暖专业 · 松柏绿体系） ===== */
  --brand: #21705F;
  --brand-deep: #185C4E;
  --brand-soft: #E8F3EF;
  --brand-gradient: linear-gradient(135deg, #21705F, #2E8A72);
  --accent: #E58A3A;
  --accent-soft: #FBF0E2;
  --success: #3B9A68;
  --warning: #DE9B3D;
  --danger: #C9504B;
  --info: #3D7FA6;
  --ink: #22332E;
  --muted: #5C6F69;
  --faint: #8A9A94;
  --bg: #F7F6F2;
  --card: #FFFFFF;
  --border: #E4E7E0;
  --shadow: 0 4rpx 16rpx rgba(34, 51, 46, 0.06);
  --radius-ctl: 12rpx;
  --radius-card: 20rpx;
  --radius-lg: 24rpx;

  min-height: 100%;
  background: var(--bg);
  color: var(--ink);
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

view,
text,
input,
button,
textarea {
  box-sizing: border-box;
}

button::after {
  border: 0;
}

.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
  background:
    linear-gradient(180deg, rgba(232, 243, 239, 0.9) 0, rgba(247, 246, 242, 0) 360rpx),
    var(--bg);
}

.surface,
.card,
.block {
  background: var(--card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow);
}

.section-title {
  font-size: 38rpx;
  line-height: 1.3;
  font-weight: 800;
  color: var(--ink);
  letter-spacing: 0;
}

.section-subtitle {
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: var(--muted);
}

.card-title,
.panel-title,
.detail-title,
.state-title {
  font-size: 31rpx;
  line-height: 1.4;
  font-weight: 800;
  color: var(--ink);
}

.muted,
.hint,
.desc {
  color: var(--muted);
}

.divider {
  height: 1rpx;
  margin: 22rpx 0;
  background: var(--border);
}

.primary-btn,
.ghost-btn,
.danger-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  margin: 0;
  padding: 0 28rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.primary-btn {
  background: linear-gradient(135deg, #21705F, #2E8A72);
  color: #ffffff;
  border: 0;
  box-shadow: 0 8rpx 20rpx rgba(33, 112, 95, 0.22);
}

.ghost-btn {
  background: #ffffff;
  color: var(--brand);
  border: 1rpx solid rgba(33, 112, 95, 0.35);
}

.danger-btn {
  background: var(--danger);
  color: #ffffff;
  border: 1rpx solid var(--danger);
  box-shadow: 0 8rpx 20rpx rgba(201, 80, 75, 0.2);
}

.primary-btn[disabled],
.ghost-btn[disabled],
.danger-btn[disabled] {
  opacity: 0.48;
  box-shadow: none;
}

.primary-btn:active,
.ghost-btn:active,
.danger-btn:active,
.entry:active,
.item:active,
.notice-item:active,
.order-item:active {
  transform: translateY(2rpx);
  opacity: 0.9;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
}

.pill-normal {
  background: var(--brand-soft);
  color: var(--brand);
}

.pill-warning {
  background: #FBF0E2;
  color: #B27221;
}

.pill-danger {
  background: #F9E7E6;
  color: var(--danger);
}

.list-empty,
.empty {
  padding: 48rpx 20rpx;
  text-align: center;
  color: var(--faint);
  font-size: 26rpx;
  line-height: 1.6;
}

input,
textarea {
  color: var(--ink);
}

.runtime-tip {
  margin-bottom: 18rpx;
  padding: 16rpx 20rpx;
  border-radius: 14rpx;
  background: #EDF4F9;
  border: 1rpx solid #CBDEEA;
  color: var(--info);
  font-size: 24rpx;
  line-height: 1.6;
}

.state-card {
  padding: 28rpx;
  margin-bottom: 18rpx;
}

.state-btn,
.action,
.action-btn {
  margin-top: 18rpx;
}

.item,
.record,
.line-item,
.qa-card,
.summary-item,
.support-box,
.notice-panel,
.scope-panel,
.password-panel,
.media-panel,
.moment {
  border-radius: 16rpx;
  background: #FAFAF7;
  border: 1rpx solid var(--border);
}

.input,
.textarea,
.picker,
.code-input,
.reason-input {
  border-radius: var(--radius-ctl);
  background: #ffffff;
  border: 1rpx solid #D7DED8;
  color: var(--ink);
}

.label,
.meta,
.sub,
.desc,
.time,
.date,
.k {
  color: var(--muted);
}

.value,
.v,
.name,
.title,
.project,
.record-title,
.qa,
.item-title {
  color: var(--ink);
}

.tag,
.template,
.template-item {
  border-radius: 999rpx;
  background: var(--brand-soft);
  color: var(--brand);
}

.photo,
.cover,
.moment-image,
.moment-video,
.product-image {
  background: #E3E8E2;
}

/* ===== 新增通用工具类（不影响既有页面） ===== */
.accent {
  color: var(--accent);
}

.accent-chip {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 18rpx;
  border-radius: 999rpx;
  background: var(--accent-soft);
  color: var(--accent);
  font-size: 22rpx;
  font-weight: 700;
}

.pill-info {
  background: #EDF4F9;
  color: var(--info);
}

.pill-success {
  background: #E7F4EC;
  color: var(--success);
}

/* ===== 统一状态/空态/骨架/列表 视觉规范（页面局部定义会自然覆盖） ===== */
.empty-card,
.state-card {
  padding: 40rpx 32rpx;
  margin-bottom: 18rpx;
  text-align: center;
}

.empty-text {
  padding: 40rpx 20rpx;
  text-align: center;
  color: var(--faint);
  font-size: 26rpx;
  line-height: 1.6;
}

.retry-btn {
  margin: 24rpx auto 0;
  min-width: 220rpx;
}

.list-footer {
  padding: 26rpx 0 6rpx;
  text-align: center;
  color: var(--faint);
  font-size: 24rpx;
}

/* 横向筛选条：胶囊风格，未选中浅底、选中品牌色 */
.filter {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 26rpx;
  margin: 0 12rpx 0 0;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid var(--border);
  color: var(--muted);
  font-size: 26rpx;
  white-space: nowrap;
}

.filter.active {
  background: var(--brand-soft);
  border-color: rgba(33, 112, 95, 0.35);
  color: var(--brand);
  font-weight: 700;
}

/* 状态徽标（正常/异常/完成/待处理），全端统一配色 */
.status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
  background: var(--brand-soft);
  color: var(--brand);
}

.status-pill.danger {
  background: #F9E7E6;
  color: var(--danger);
}

.status-pill.warning {
  background: #FBF0E2;
  color: #B27221;
}

.status-pill.done,
.status-pill.success {
  background: #E7F4EC;
  color: var(--success);
}

.status-pill.pending,
.status-pill.info {
  background: #EDF4F9;
  color: var(--info);
}

/* 通用骨架屏工具类（非组件场景可直接使用） */
.skeleton-line {
  height: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ECEFEA 25%, #F5F7F3 37%, #ECEFEA 63%);
  background-size: 400% 100%;
  animation: skeleton-shimmer 1.3s ease infinite;
}

@keyframes skeleton-shimmer {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}
