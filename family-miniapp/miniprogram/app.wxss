page {
  background:
    radial-gradient(circle at top left, rgba(240, 199, 135, 0.18) 0%, rgba(240, 199, 135, 0) 34%),
    radial-gradient(circle at top right, rgba(44, 122, 132, 0.16) 0%, rgba(44, 122, 132, 0) 32%),
    linear-gradient(180deg, #f7f4ee 0%, #edf3f6 48%, #e8eef3 100%);
  color: #1f2937;
  min-height: 100%;
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  box-sizing: border-box;
  padding: 28rpx 24rpx calc(36rpx + env(safe-area-inset-bottom));
}

.surface {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 56rpx rgba(26, 42, 57, 0.09);
  backdrop-filter: blur(18rpx);
}

.surface::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  border: 1rpx solid rgba(25, 79, 94, 0.05);
  pointer-events: none;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #194f5e;
  letter-spacing: 0.6rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: #667788;
  line-height: 1.7;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.muted {
  color: #6b7280;
}

.divider {
  height: 1rpx;
  background: rgba(148, 163, 184, 0.2);
  margin: 20rpx 0;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.pill-normal {
  background: #e6f6ed;
  color: #0f766e;
}

.pill-warning {
  background: #fff4e8;
  color: #b45309;
}

.pill-danger {
  background: #ffefef;
  color: #b91c1c;
}

.primary-btn {
  background: linear-gradient(120deg, #194f5e, #2c7a84);
  color: #fff;
  border-radius: 18rpx;
  font-size: 28rpx;
  border: none;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 28rpx;
  box-shadow: 0 16rpx 30rpx rgba(25, 79, 94, 0.2);
}

.ghost-btn {
  background: rgba(242, 247, 248, 0.92);
  border: 1rpx solid rgba(44, 122, 132, 0.2);
  color: #194f5e;
  border-radius: 18rpx;
  font-size: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 28rpx;
}

.danger-btn {
  background: linear-gradient(120deg, #b91c1c, #dc2626);
  color: #fff;
  border-radius: 18rpx;
  font-size: 28rpx;
  border: none;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 28rpx;
}

.list-empty {
  padding: 40rpx 20rpx;
  text-align: center;
  color: #6b7280;
  font-size: 24rpx;
}

@media screen and (max-width: 360px) {
  .container {
    padding-left: 20rpx;
    padding-right: 20rpx;
  }

  .section-title {
    font-size: 32rpx;
  }

  .primary-btn,
  .ghost-btn,
  .danger-btn {
    font-size: 26rpx;
  }
}
