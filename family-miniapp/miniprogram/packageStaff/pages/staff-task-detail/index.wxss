.detail-card {
  padding: 28rpx;
}

.detail-title {
  color: #22332E;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.35;
}

.detail-meta {
  margin-top: 10rpx;
  color: #73808c;
  font-size: 24rpx;
}

.info-line {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0 0;
  color: #495867;
  font-size: 25rpx;
}

.check-list {
  display: grid;
  gap: 12rpx;
  margin-top: 18rpx;
}

.check-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f6f8fa;
  color: #465563;
  font-size: 24rpx;
}

.check-item.checked {
  background: #E8F3EF;
  color: #21705F;
  font-weight: 850;
}

.check-dot {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #dbe3ea;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 900;
}

.check-item.checked .check-dot {
  background: #21705F;
}

.tool-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.tool-btn {
  height: 76rpx;
  border-radius: 18rpx;
  background: #E8F3EF;
  color: #185C4E;
  font-size: 25rpx;
  font-weight: 850;
  line-height: 76rpx;
}

.voice-panel {
  margin-top: 16rpx;
}

.voice-btn {
  width: 100%;
  height: 76rpx;
  border-radius: 18rpx;
  background: #eef6ff;
  color: #3D7FA6;
  font-size: 25rpx;
  font-weight: 850;
  line-height: 76rpx;
}

.voice-btn.recording {
  background: #dff7dc;
  color: #166534;
}

.voice-chip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #f2f8f5;
  color: #21705F;
  font-size: 23rpx;
  font-weight: 850;
}

.voice-clear {
  color: #C9504B;
}

.scan-text {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #f7f3e8;
  color: #7a5a12;
  font-size: 23rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 16rpx;
}

.photo {
  width: 100%;
  height: 150rpx;
  border-radius: 14rpx;
  background: #eef2f5;
}

.remark {
  width: 100%;
  min-height: 220rpx;
  box-sizing: border-box;
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f5f7fa;
  color: #22332E;
  font-size: 26rpx;
}

.submit-btn {
  width: 100%;
  margin-top: 20rpx;
}

.record-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(10, 18, 15, 0.28);
}

.record-card {
  width: 300rpx;
  padding: 36rpx 24rpx;
  border-radius: 24rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.94);
}

.record-mic {
  width: 76rpx;
  height: 76rpx;
  margin: 0 auto 18rpx;
  border-radius: 50%;
  background: #21705F;
  box-shadow: 0 0 0 18rpx rgba(31, 122, 105, 0.12);
}

.record-title {
  color: #22332E;
  font-size: 28rpx;
  font-weight: 800;
}

.record-text {
  margin-top: 8rpx;
  color: #697a74;
  font-size: 22rpx;
}
