<view class="container">
  <view class="section-title">后勤执行</view>
  <view class="section-subtitle">维修派单、到场处理、餐食配送和签收回执</view>

  <view class="quick-actions">
    <button class="ghost-btn quick-btn" bindtap="goMaterial">物资申领 / 补给</button>
    <button class="ghost-btn quick-btn" bindtap="goRepairs">维修处理 / 验收</button>
    <button class="ghost-btn quick-btn" bindtap="goMeals">送餐签收 / 反馈</button>
  </view>

  <view class="mode-tabs">
    <view class="mode-tab {{activeTab === 'LOGISTICS' ? 'active' : ''}}" data-tab="LOGISTICS" bindtap="switchTab">维修工单（{{maintenancePending}}）</view>
    <view class="mode-tab {{activeTab === 'MEAL' ? 'active' : ''}}" data-tab="MEAL" bindtap="switchTab">送餐任务（{{mealPending}}）</view>
  </view>

  <view class="surface state-card" wx:if="{{loading}}">
    <view class="state-title">正在加载后勤任务</view>
  </view>

  <view class="surface state-card" wx:if="{{!loading && loadError}}">
    <view class="state-title">后勤任务加载失败</view>
    <view class="section-subtitle">{{loadError}}</view>
    <button class="ghost-btn retry-btn" bindtap="loadData">重新加载</button>
  </view>

  <view class="surface panel" wx:if="{{!loading && !loadError && activeTab === 'LOGISTICS'}}">
    <view class="panel-title">维修工单</view>
    <view class="section-subtitle" wx:if="{{maintenanceTasks.length === 0}}">暂无维修工单。</view>
    <block wx:for="{{maintenanceTasks}}" wx:key="id">
      <view class="work-row" data-id="{{item.id}}" bindtap="openRepair">
        <view>
          <view class="work-title">{{item.title}}</view>
          <view class="work-meta">{{item.room}} · {{item.time}} · {{item.status}}</view>
        </view>
        <text class="work-action">{{item.actionText}}</text>
      </view>
    </block>
  </view>

  <view class="surface panel" wx:if="{{!loading && !loadError && activeTab === 'MEAL'}}">
    <view class="panel-title">餐食配送</view>
    <view class="section-subtitle" wx:if="{{mealTasks.length === 0}}">暂无送餐任务。</view>
    <block wx:for="{{mealTasks}}" wx:key="id">
      <view class="work-row" data-id="{{item.id}}" bindtap="openMeal">
        <view>
          <view class="work-title">{{item.title}}</view>
          <view class="work-meta">{{item.resident}} · {{item.room}} · {{item.time}} · {{item.status}}</view>
        </view>
        <text class="work-action">{{item.actionText}}</text>
      </view>
    </block>
  </view>
</view>
