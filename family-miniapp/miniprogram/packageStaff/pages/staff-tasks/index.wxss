/* ===== 员工任务列表 · 紧凑高效 ===== */

/* 工作台入口卡片 */
.workbench-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.workbench-card {
  min-height: 120rpx;
  padding: 22rpx;
  border-left: 6rpx solid var(--brand);
}

.workbench-card:active {
  transform: translateY(2rpx);
  opacity: 0.9;
}

.workbench-title {
  color: var(--brand-deep);
  font-size: 28rpx;
  font-weight: 800;
}

.workbench-desc {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 23rpx;
  line-height: 1.35;
}

/* 筛选条：胶囊易点 */
.filter-scroll {
  margin: 22rpx 0 8rpx;
  white-space: nowrap;
}

.filter {
  display: inline-flex;
  align-items: center;
  height: 64rpx;
  margin-right: 12rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: var(--card);
  border: 1rpx solid var(--border);
  color: var(--muted);
  font-size: 25rpx;
  font-weight: 700;
}

.filter.active {
  background: linear-gradient(135deg, #21705F, #2E8A72);
  border-color: transparent;
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(33, 112, 95, 0.24);
}

/* 任务列表面板 */
.panel {
  margin-top: 14rpx;
  padding: 8rpx 26rpx;
}

.empty-text {
  padding: 40rpx 0;
  text-align: center;
  color: var(--faint);
  font-size: 26rpx;
}

/* 任务行：紧凑清晰 */
.task-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid var(--border);
}

.task-row:first-of-type {
  border-top: 0;
}

.task-row:active {
  opacity: 0.8;
}

.task-main {
  flex: 1;
  min-width: 0;
}

.task-title {
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.4;
}

.task-meta {
  margin-top: 8rpx;
  color: var(--faint);
  font-size: 23rpx;
}

/* 状态徽章：浅底深字 */
.task-status {
  display: inline-flex;
  align-items: center;
  margin-top: 10rpx;
  min-height: 40rpx;
  padding: 2rpx 16rpx;
  border-radius: 999rpx;
  background: #EDF4F9;
  color: var(--info);
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.4;
}

/* 分批加载提示 */
.list-footer {
  padding: 24rpx 0;
  text-align: center;
  color: var(--faint);
  font-size: 23rpx;
}

/* 行内操作：品牌胶囊按钮，易点 */
.task-action {
  flex: none;
  display: inline-flex;
  align-items: center;
  min-height: 60rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #21705F, #2E8A72);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  white-space: nowrap;
  box-shadow: 0 6rpx 14rpx rgba(33, 112, 95, 0.22);
}
