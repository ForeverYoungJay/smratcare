.card {
  padding: 32rpx;
}

.user-name {
  color: #22332E;
  font-size: 38rpx;
  font-weight: 900;
}

.user-sub {
  margin-top: 10rpx;
  color: #5C6F69;
  font-size: 24rpx;
  line-height: 1.5;
}

.role-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 22rpx;
}

.quick-list {
  margin-top: 26rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f6f8fa;
}

.quick-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx;
  border-top: 1rpx solid #edf1f5;
}

.quick-row:first-child {
  border-top: 0;
}

.quick-title {
  color: #22332E;
  font-size: 26rpx;
  font-weight: 900;
}

.quick-desc {
  margin-top: 6rpx;
  color: #73808c;
  font-size: 22rpx;
}

.quick-arrow {
  color: #9aa7b3;
  font-size: 38rpx;
}

.action {
  width: 100%;
  margin-top: 22rpx;
}

/* 本月工作量统计 */
.stats-block {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(33, 112, 95, 0.1), rgba(255, 255, 255, 0) 60%), #f7faf9;
}

.stats-title {
  color: #22332E;
  font-size: 27rpx;
  font-weight: 900;
}

.stats-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.stats-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stats-cell strong {
  color: #21705F;
  font-size: 32rpx;
  font-weight: 900;
}

.stats-cell text {
  color: #73808c;
  font-size: 21rpx;
}

.stats-records {
  margin-top: 16rpx;
  border-top: 1rpx solid rgba(33, 112, 95, 0.12);
  padding-top: 12rpx;
}

.stats-record {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}

.record-title {
  flex: 1;
  color: #465563;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-date {
  color: #9aa7b3;
  font-size: 22rpx;
}
