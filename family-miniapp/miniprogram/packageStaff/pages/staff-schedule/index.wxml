<view class="container">
  <view class="section-title">我的排班</view>
  <view class="section-subtitle">查看班次、责任区域和移动端打卡状态</view>

  <state-view
    loading="{{loading}}"
    error="{{loadError}}"
    skeleton-rows="{{3}}"
    bindretry="loadData"
  />

  <view class="surface attendance-card" wx:if="{{!loading && !loadError && attendance}}">
    <view class="attendance-head">
      <view>
        <view class="attendance-title">今日考勤</view>
        <view class="attendance-meta">应到 {{attendance.expectedWorkStart || '-'}} · 应退 {{attendance.expectedWorkEnd || '-'}}</view>
      </view>
      <text class="status">{{attendance.todayStatusLabel || attendance.status || '未打卡'}}</text>
    </view>
    <view class="attendance-meta detail" wx:if="{{attendance.checkInTime || attendance.checkOutTime}}">
      上班 {{attendance.checkInTime || '-'}} · 下班 {{attendance.checkOutTime || '-'}}
    </view>
    <view class="attendance-feedback success-text" wx:if="{{punchSuccess}}">{{punchSuccess}}</view>
    <view class="attendance-feedback error-text" wx:if="{{punchError}}">{{punchError}}</view>
    <view class="punch-grid">
      <block wx:for="{{punchActions}}" wx:key="action">
        <button class="punch-btn" loading="{{punching}}" data-action="{{item.action}}" bindtap="punch">{{item.label}}</button>
      </block>
    </view>
  </view>

  <view class="surface panel" wx:if="{{!loading && !loadError}}">
    <view class="panel-head-row">
      <view class="view-tabs">
        <view class="view-tab {{viewMode === 'calendar' ? 'active' : ''}}" data-mode="calendar" bindtap="switchView">月历</view>
        <view class="view-tab {{viewMode === 'list' ? 'active' : ''}}" data-mode="list" bindtap="switchView">列表</view>
      </view>
      <view class="swap-link" bindtap="goShiftSwap">申请换班 ›</view>
    </view>

    <block wx:if="{{viewMode === 'calendar'}}">
      <view class="calendar-month">{{calendar.monthLabel}}</view>
      <view class="calendar-grid">
        <view class="calendar-weekday" wx:for="{{weekdays}}" wx:key="*this">{{item}}</view>
        <block wx:for="{{calendar.cells}}" wx:key="key">
          <view wx:if="{{item.blank}}" class="calendar-cell blank"></view>
          <view wx:else
            class="calendar-cell {{item.isToday ? 'today' : ''}} {{item.dateStr === selectedDate ? 'selected' : ''}}"
            data-date="{{item.dateStr}}" bindtap="pickDay">
            <view class="calendar-day">{{item.day}}</view>
            <view class="calendar-shift {{item.hasShift ? 'on' : ''}}">{{item.hasShift ? item.shiftLabel : ''}}</view>
          </view>
        </block>
      </view>
      <view class="day-detail">
        <view class="day-detail-title">{{selectedDate}} 班次</view>
        <view class="list-empty" wx:if="{{!selectedItems.length}}">当天休息，无排班安排</view>
        <view class="schedule-row" wx:for="{{selectedItems}}" wx:key="index">
          <view class="schedule-main">
            <view class="schedule-title">{{item.shift}} · {{item.time}}</view>
            <view class="schedule-meta">{{item.area}}</view>
          </view>
          <text class="status">{{item.status}}</text>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="state-title" wx:if="{{!schedule.length}}">暂无排班记录</view>
      <block wx:for="{{schedule}}" wx:key="date">
        <view class="schedule-row">
          <view class="date-chip">{{item.date}}</view>
          <view class="schedule-main">
            <view class="schedule-title">{{item.shift}} · {{item.time}}</view>
            <view class="schedule-meta">{{item.area}}</view>
          </view>
          <text class="status">{{item.status}}</text>
        </view>
      </block>
    </block>
  </view>
</view>
