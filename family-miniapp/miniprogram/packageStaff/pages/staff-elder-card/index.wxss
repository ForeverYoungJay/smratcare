.search-card {
  margin-top: 18rpx;
  padding: 26rpx;
}

.search-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 20rpx;
}

.search-btn {
  flex: 1;
}

.scan-btn {
  flex: 1;
}

.panel {
  margin-top: 18rpx;
  padding: 26rpx;
}

.match-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 4rpx;
  border-bottom: 1rpx solid rgba(33, 112, 95, 0.1);
}

.match-row:last-child {
  border-bottom: none;
}

.match-name {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 700;
}

.match-meta {
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 24rpx;
}

.match-arrow {
  color: var(--muted);
  font-size: 36rpx;
}

.card-head {
  margin-top: 18rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(33, 112, 95, 0.12), rgba(255, 255, 255, 0) 60%), var(--card);
  border-color: rgba(33, 112, 95, 0.22);
}

.card-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-name {
  color: var(--ink);
  font-size: 36rpx;
  font-weight: 800;
}

.card-meta {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 24rpx;
}

.risk-panel {
  border-color: rgba(201, 80, 75, 0.28);
}

.info-row {
  display: flex;
  gap: 18rpx;
  padding: 12rpx 0;
}

.info-label {
  flex: none;
  width: 130rpx;
  color: var(--muted);
  font-size: 24rpx;
}

.info-value {
  flex: 1;
  color: var(--ink);
  font-size: 26rpx;
  line-height: 1.5;
}

.order-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(33, 112, 95, 0.1);
}

.order-row:last-child {
  border-bottom: none;
}

.order-content {
  color: var(--ink);
  font-size: 27rpx;
  font-weight: 600;
}

.order-meta {
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 23rpx;
}

.call-btn {
  margin-top: 20rpx;
}

.reset-btn {
  margin-top: 20rpx;
}
