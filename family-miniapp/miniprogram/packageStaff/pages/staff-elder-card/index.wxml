<view class="container">
  <view class="section-title">床边档案速查</view>
  <view class="section-subtitle">扫老人腕带 / 床位码，或按姓名搜索，现场即刻查看护理关键信息</view>

  <view class="surface search-card">
    <input class="input-line" value="{{keyword}}" placeholder="姓名 / 老人编码 / 扫码值" confirm-type="search" bindinput="onKeywordInput" bindconfirm="onSearch" />
    <view class="search-actions">
      <button class="primary-btn search-btn" bindtap="onSearch">搜索</button>
      <button class="ghost-btn scan-btn" bindtap="scanCode">扫码识别</button>
    </view>
  </view>

  <state-view
    loading="{{loading}}"
    error="{{loadError}}"
    empty="{{!loading && !loadError && searched && !card && matches.length === 0}}"
    empty-text="未找到匹配的老人"
    empty-hint="确认腕带码清晰，或换姓名关键字再试。"
    skeleton-rows="{{3}}"
    bindretry="onSearch"
  />

  <view class="surface panel" wx:if="{{!loading && matches.length}}">
    <view class="panel-title">找到 {{matches.length}} 位，点选查看</view>
    <view class="match-row" wx:for="{{matches}}" wx:key="elderId" data-id="{{item.elderId}}" bindtap="pickMatch">
      <view>
        <view class="match-name">{{item.name}}</view>
        <view class="match-meta">{{item.careLevel}} · {{item.roomText}}</view>
      </view>
      <text class="match-arrow">›</text>
    </view>
  </view>

  <block wx:if="{{!loading && card}}">
    <view class="surface card-head">
      <view class="card-name-row">
        <view class="card-name">{{card.name}}</view>
        <text class="status-pill">{{card.careLevel}}</text>
      </view>
      <view class="card-meta">{{card.gender}} · {{card.age}} 岁 · {{card.roomText}}</view>
      <view class="card-meta">入住日期：{{card.admissionDate}} · 血型：{{card.bloodType}}</view>
    </view>

    <view class="surface panel risk-panel">
      <view class="panel-title">风险与禁忌</view>
      <view class="info-row"><text class="info-label">风险标记</text><text class="info-value">{{card.riskFlags}}</text></view>
      <view class="info-row"><text class="info-label">过敏史</text><text class="info-value">{{card.allergyHistory}}</text></view>
      <view class="info-row"><text class="info-label">慢性病</text><text class="info-value">{{card.chronicDisease}}</text></view>
    </view>

    <view class="surface panel">
      <view class="panel-title">在执行医嘱（{{card.activeOrders.length}}）</view>
      <view class="list-empty" wx:if="{{!card.activeOrders.length}}">当前没有在执行的医嘱</view>
      <view class="order-row" wx:for="{{card.activeOrders}}" wx:key="index">
        <view class="order-content">{{item.content}}</view>
        <view class="order-meta">{{item.usageText}} · {{item.doctorName}}</view>
      </view>
    </view>

    <view class="surface panel">
      <view class="panel-title">紧急联系人</view>
      <view class="info-row"><text class="info-label">联系人</text><text class="info-value">{{card.emergencyContact}}</text></view>
      <view class="info-row"><text class="info-label">电话</text><text class="info-value">{{card.emergencyPhone || '未登记'}}</text></view>
      <button class="primary-btn call-btn" wx:if="{{card.emergencyPhone}}" bindtap="callEmergency">拨打紧急联系电话</button>
    </view>

    <button class="ghost-btn reset-btn" bindtap="backToSearch">重新查询</button>
  </block>
</view>
