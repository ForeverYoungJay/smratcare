.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.summary-card {
  padding: 20rpx 12rpx;
  text-align: center;
}

.summary-card-hover {
  opacity: 0.88;
}

.summary-card text,
.summary-card strong {
  display: block;
}

.summary-card text {
  color: #73808c;
  font-size: 22rpx;
  font-weight: 800;
}

.summary-card strong {
  margin-top: 8rpx;
  color: #21705F;
  font-size: 38rpx;
  font-weight: 900;
}

.panel {
  margin-top: 22rpx;
  padding: 26rpx;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.panel-entry {
  color: #21705F;
  font-size: 23rpx;
  font-weight: 850;
}

.work-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #edf1f5;
}
.work-row:first-of-type { border-top: 0; }
.work-row-hover { opacity: 0.7; }
.work-title { color: #22332E; font-size: 28rpx; font-weight: 900; }
.work-meta { margin-top: 8rpx; color: #73808c; font-size: 23rpx; }
.work-action { color: #3D7FA6; font-size: 24rpx; font-weight: 900; white-space: nowrap; }

.more-link {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #edf1f5;
  color: #21705F;
  font-size: 24rpx;
  font-weight: 850;
  text-align: center;
}
