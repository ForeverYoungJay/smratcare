.mode-tabs {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin: 20rpx 0;
  padding: 8rpx;
  border-radius: 22rpx;
  background: #e8efec;
}

.mode-tab {
  height: 68rpx;
  border-radius: 18rpx;
  color: #60716b;
  font-size: 25rpx;
  font-weight: 850;
  line-height: 68rpx;
  text-align: center;
}

.mode-tab.active {
  background: #ffffff;
  color: #21705F;
  box-shadow: 0 10rpx 24rpx rgba(44, 83, 72, 0.12);
}

.state-card,
.empty-card {
  margin-top: 22rpx;
  padding: 34rpx;
}

.retry-btn {
  margin-top: 20rpx;
}

.task-card,
.form-card {
  margin-top: 22rpx;
  padding: 26rpx;
}

.inline-state {
  margin-top: 18rpx;
}

.success-state {
  background: #E8F3EF;
}

.error-state {
  background: #fff3f2;
}

.clinical-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 14rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f6f8f7;
  border: 2rpx solid transparent;
}

.clinical-row.active {
  background: #E8F3EF;
  border-color: #79b7a4;
}

.clinical-title {
  color: #22332E;
  font-size: 28rpx;
  font-weight: 900;
}

.clinical-meta {
  margin-top: 8rpx;
  color: #73808c;
  font-size: 23rpx;
}

.clinical-status,
.task-time {
  flex: none;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #FBF0E2;
  color: #B27221;
  font-size: 21rpx;
  font-weight: 900;
}

.form-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.form-subtitle {
  margin-top: 8rpx;
  color: #73808c;
  font-size: 23rpx;
}

.check-grid {
  display: grid;
  gap: 12rpx;
  margin-top: 20rpx;
}

.check-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 17rpx;
  border-radius: 16rpx;
  background: #f6f8fa;
  color: #465563;
  font-size: 24rpx;
}

.check-item.checked {
  background: #E8F3EF;
  color: #21705F;
  font-weight: 850;
}

.check-dot {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #dbe3ea;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 900;
}

.check-item.checked .check-dot {
  background: #21705F;
}

.field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.tool-btn {
  height: 76rpx;
  border-radius: 18rpx;
  background: #E8F3EF;
  color: #185C4E;
  font-size: 25rpx;
  font-weight: 850;
  line-height: 76rpx;
}

.tool-btn-full {
  width: 100%;
  margin-top: 18rpx;
}

.tool-btn-hover {
  background: #d7ece4;
}

.clinical-row-hover {
  background: #eef3f1;
}

.scan-text {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #f7f3e8;
  color: #7a5a12;
  font-size: 23rpx;
}

.field {
  margin-top: 22rpx;
}

.field-grid .field {
  margin-top: 0;
}

.field-label {
  margin-bottom: 10rpx;
  color: #60716b;
  font-size: 23rpx;
  font-weight: 850;
}

.picker-line,
.input-line,
.textarea-line {
  width: 100%;
  box-sizing: border-box;
  border-radius: 14rpx;
  border: 1rpx solid #D7DED8;
  background: #ffffff;
  color: #22332E;
  font-size: 25rpx;
}

.picker-line,
.input-line {
  min-height: 74rpx;
  line-height: 74rpx;
  padding: 0 18rpx;
}

.textarea-line {
  min-height: 140rpx;
  padding: 18rpx;
  line-height: 1.55;
}

.textarea-line.small {
  min-height: 116rpx;
}

.submit-btn {
  width: 100%;
  margin-top: 24rpx;
}

.submit-btn.disabled {
  opacity: 0.5;
}

.checklist-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
}

.checklist-head .field-label {
  margin-bottom: 0;
}

.checklist-progress {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #FBF0E2;
  color: #B27221;
  font-size: 21rpx;
  font-weight: 900;
}

.checklist-progress.done {
  background: #E8F3EF;
  color: #21705F;
}
