<view class="container">
  <view class="section-title">请假调班</view>
  <view class="section-subtitle">现场员工移动发起审批，自动进入后台 OA 审批流</view>

  <view class="type-tabs">
    <view class="type-tab {{activeType === 'LEAVE' ? 'active' : ''}}" data-type="LEAVE" bindtap="switchType">请假</view>
    <view class="type-tab {{activeType === 'SHIFT_CHANGE' ? 'active' : ''}}" data-type="SHIFT_CHANGE" bindtap="switchType">调班</view>
  </view>

  <view class="surface form-card">
    <view class="panel-title">{{activeType === 'LEAVE' ? '请假申请' : '调班申请'}}</view>
    <view class="state-card inline-state success-state" wx:if="{{submitSuccess}}">
      <view class="state-title">审批申请已提交</view>
      <view class="section-subtitle">{{submitSuccess}}</view>
      <view class="section-subtitle" wx:if="{{lastApprovalSummary}}">最近一次：{{lastApprovalSummary}}</view>
    </view>
    <view class="state-card inline-state error-state" wx:if="{{submitError}}">
      <view class="state-title">审批提交失败</view>
      <view class="section-subtitle">{{submitError}}</view>
    </view>

    <view class="field" wx:if="{{activeType === 'LEAVE'}}">
      <view class="field-label">请假类型</view>
      <picker mode="selector" range="{{leaveTypes}}" value="{{leaveTypeIndex}}" bindchange="onLeaveTypeChange">
        <view class="picker-line">{{leaveTypes[leaveTypeIndex]}}</view>
      </picker>
    </view>

    <view class="field-grid">
      <view class="field">
        <view class="field-label">开始日期</view>
        <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="picker-line">{{startDate}}</view>
        </picker>
      </view>
      <view class="field">
        <view class="field-label">开始时间</view>
        <picker mode="time" value="{{startTime}}" bindchange="onStartTimeChange">
          <view class="picker-line">{{startTime}}</view>
        </picker>
      </view>
      <view class="field">
        <view class="field-label">结束日期</view>
        <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
          <view class="picker-line">{{endDate}}</view>
        </picker>
      </view>
      <view class="field">
        <view class="field-label">结束时间</view>
        <picker mode="time" value="{{endTime}}" bindchange="onEndTimeChange">
          <view class="picker-line">{{endTime}}</view>
        </picker>
      </view>
    </view>

    <view wx:if="{{activeType === 'SHIFT_CHANGE'}}">
      <view class="field">
        <view class="field-label">调班对象</view>
        <input class="input-line" value="{{targetStaffName}}" placeholder="填写同事姓名或班组说明" bindinput="onTargetStaffInput" />
      </view>
      <view class="field-grid">
        <view class="field">
          <view class="field-label">目标班次日期</view>
          <picker mode="date" value="{{targetShiftDate}}" bindchange="onTargetShiftDateChange">
            <view class="picker-line">{{targetShiftDate}}</view>
          </picker>
        </view>
        <view class="field">
          <view class="field-label">目标班次时间</view>
          <picker mode="time" value="{{targetShiftTime}}" bindchange="onTargetShiftTimeChange">
            <view class="picker-line">{{targetShiftTime}}</view>
          </picker>
        </view>
      </view>
    </view>

    <view class="field">
      <view class="field-label">申请原因</view>
      <textarea class="reason-box" value="{{reason}}" placeholder="说明原因、现场交接安排或已沟通对象" bindinput="onReasonInput" />
    </view>

    <checkbox-group bindchange="onPolicyChange" wx:if="{{activeType === 'LEAVE'}}">
      <label class="policy-row">
        <checkbox value="yes" checked="{{policyAcknowledged}}" color="#21705F" />
        <text>我已阅读并确认请假制度，知晓排班补位要求</text>
      </label>
    </checkbox-group>

    <button class="primary-btn submit-btn" loading="{{submitting}}" bindtap="submitApproval">提交审批</button>
  </view>

  <view class="surface state-card" wx:if="{{loadError}}">
    <view class="state-title">审批记录加载失败</view>
    <view class="section-subtitle">{{loadError}}</view>
    <button class="ghost-btn retry-btn" bindtap="loadData">重新加载</button>
  </view>

  <view class="surface panel">
    <view class="panel-head">
      <text class="panel-title">我的申请</text>
      <text class="section-subtitle">按时间倒序展示</text>
    </view>
    <view class="list-empty" wx:if="{{loading}}">正在加载审批申请...</view>
    <view class="list-empty" wx:if="{{!loading && approvals.length === 0}}">暂无审批申请</view>
    <view class="approval-row" wx:for="{{approvals}}" wx:key="id">
      <view class="approval-head">
        <view>
          <view class="approval-title">{{item.title}}</view>
          <view class="approval-meta">{{item.typeText}} · {{item.timeText}}</view>
        </view>
        <text class="status-pill {{item.status === 'REJECTED' ? 'danger' : item.status === 'APPROVED' ? 'success' : ''}}">{{item.statusText}}</text>
      </view>
      <view class="approval-remark">{{item.remark || '无备注'}}</view>
      <view class="approval-create">提交时间：{{item.createText || '-'}}</view>
    </view>
    <view class="surface state-card" wx:if="{{!loading && approvals.length && loadingMore}}">
      <view class="section-subtitle">正在加载更多审批记录...</view>
    </view>
    <view class="surface state-card" wx:elif="{{!loading && approvals.length && hasMore}}">
      <view class="section-subtitle">已加载 {{approvals.length}} 条审批记录</view>
      <button class="ghost-btn retry-btn" bindtap="loadMore">继续加载</button>
    </view>
  </view>
</view>
